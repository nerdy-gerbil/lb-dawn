{% comment %}
  ============================================================
  Klarna productVariants Bloat Fix — FINAL
  ------------------------------------------------------------
  REQUIREMENTS:
  - Keep the Klarna app block ENABLED in the theme customiser
  - Do NOT add any custom <klarna-placement> element
  - Remove any previous Klarna snippets (v1–v5) from theme.liquid
  - Paste this snippet in theme.liquid immediately BEFORE
    the closing </head> tag

  WHY THIS WORKS — THE EXACT EXECUTION ORDER:
  ─────────────────────────────────────────────
  1. theme.liquid <head> runs → OUR SNIPPET RUNS HERE
     We define window.appBlockPlacements as a proxy array
     with a custom .push() that strips productVariants.

  2. Shopify renders the Klarna app block inline <script>
     in <body>. It does:
       window.appBlockPlacements ||= [];
       if (window.klarnaAppBlocksManager) {
         window.klarnaAppBlocksManager.push({ productVariants: [...], ... });
       }
     Because our proxy array already exists, the ||= does
     nothing. klarnaAppBlocksManager does NOT exist yet
     (index.js is deferred), so it falls into the else
     branch and calls:
       window.appBlockPlacements.push({ productVariants: [...], ... })
     OUR CUSTOM PUSH FIRES HERE — strips productVariants,
     fixes country/currency, then stores the cleaned object.

  3. index.js runs (deferred, after all inline scripts):
       const A = window.appBlockPlacements || [];
       new KlarnaManager(A)  →  A.forEach(manager.push)
     The manager processes our already-cleaned data object.
     productVariants is [], storefrontCountry is 'GB',
     storefrontCurrency is 'GBP'. The locale check passes,
     the currency check passes, the widget renders. ✓

  CONFIRMED STORE CONFIG (live browser inspection):
  - GB is in mid_locales → ["en-GB"] ✓
  - store currency: GBP ✓
  - fallback_placement: top-strip-promotion-badge
  ============================================================
{% endcomment %}

{% if template.name == 'product' %}
<script>
(function () {
  'use strict';

  var COUNTRY  = 'GB';
  var CURRENCY = 'GBP';

  /* ── Step 1: Create the proxy array BEFORE the app block script runs ── */
  var _items = [];

  /* Override push so we can intercept the data object */
  _items.push = function () {
    for (var i = 0; i < arguments.length; i++) {
      var data = arguments[i];
      if (data && typeof data === 'object') {
        /* Strip the 220-245 KB variant array */
        data.productVariants = [];
        /* Fix country/currency for UK store so locale check passes */
        data.storefrontCountry  = COUNTRY;
        data.storefrontCurrency = CURRENCY;
      }
      Array.prototype.push.call(_items, data);
    }
    return _items.length;
  };

  /* Make the proxy array look like a real array to the ||= operator */
  Object.defineProperty(_items, 'length', {
    get: function () { return _items.length; },
    configurable: true
  });

  /* ── Step 2: Assign our proxy as window.appBlockPlacements ── */
  /* The app block script does: window.appBlockPlacements ||= []  */
  /* Since our proxy is already assigned and truthy, ||= is a no-op */
  window.appBlockPlacements = _items;

})();
</script>
{% endif %}
