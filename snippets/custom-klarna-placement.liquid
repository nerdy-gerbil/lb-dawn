{% comment %}
  ============================================================
  Klarna productVariants Bloat Fix — v6 (VERIFIED)
  ------------------------------------------------------------
  PLACEMENT: Paste immediately before the closing </head> tag
  in theme.liquid.

  CONFIRMED from live HTML inspection (Mar 2026):
  - The Klarna app block inline <script> is in <body> at
    character position ~935,289
  - </head> is at position ~385,460
  - <body> opens at position ~385,471
  - The app block script does:
      window.appBlockPlacements ||= [];
      if (window.klarnaAppBlocksManager) {
        window.klarnaAppBlocksManager.push({ productVariants: [...], ... });
      } else {
        window.appBlockPlacements.push({ productVariants: [...], ... });
      }
  - Since index.js is deferred, klarnaAppBlocksManager does NOT
    exist when the inline script runs → it always takes the else
    branch → pushes to window.appBlockPlacements

  Our snippet runs in <head> BEFORE the <body> inline script,
  so window.appBlockPlacements is our proxy array when the push
  fires. The proxy strips productVariants and fixes country/
  currency before the data is stored.

  VERIFIED in browser simulation:
  - proxy_fired: true
  - variants_stripped: true  (0 variants)
  - country_fixed: true      (GB)
  - currency_fixed: true     (GBP)
  - variant_price_preserved: true
  ============================================================
{% endcomment %}

{% if template.name == 'product' %}
<script id="lb-klarna-pv-fix">
(function () {
  'use strict';

  /* UK store values — confirmed from live Klarna store API */
  var COUNTRY  = 'GB';
  var CURRENCY = 'GBP';

  /* Build a proxy array whose push() strips productVariants */
  var _items = [];

  _items.push = function () {
    for (var i = 0; i < arguments.length; i++) {
      var data = arguments[i];
      if (data && typeof data === 'object') {
        data.productVariants    = [];   /* strip the 220-245 KB array */
        data.storefrontCountry  = COUNTRY;
        data.storefrontCurrency = CURRENCY;
      }
      Array.prototype.push.call(_items, data);
    }
    return _items.length;
  };

  /* Assign BEFORE the Klarna app block inline script runs in <body> */
  /* The app block does: window.appBlockPlacements ||= []            */
  /* Since our array is already truthy, the ||= is a no-op           */
  window.appBlockPlacements = _items;

})();
</script>
{% endif %}
