{% comment %}Klarna productVariants bloat fix — empties the variant array before Klarna reads it{% endcomment %}
{% if template.name == 'product' %}
<script>
  (function () {
    // Override appBlockPlacements before Klarna's index.js reads productVariants
    // This prevents the 220-245 KB variant array from being processed
    // The widget still renders correctly via its own API calls
    var _push = Array.prototype.push;
    Object.defineProperty(window, 'appBlockPlacements', {
      set: function (val) {
        if (Array.isArray(val)) {
          val = val.map(function (p) {
            if (p && p.dataKey && p.dataKey.indexOf('klarna') > -1 || p.selector === 'lb-klarna-placement') {
              p.productVariants = [];
            }
            return p;
          });
        }
        Object.defineProperty(window, 'appBlockPlacements', { value: val, writable: true, configurable: true });
      },
      configurable: true
    });
  })();
</script>
{% endif %}
