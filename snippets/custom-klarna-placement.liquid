{% comment %}
  ============================================================
  Klarna On-Site Messaging — Lazy-Load Replacement v2
  ------------------------------------------------------------
  PREREQUISITES:
  1. Disable the Klarna app BLOCK on the product template
     (remove it from the product template sections in the
     theme customiser — NOT the app embed, which does not
     exist for Klarna).
  2. Add the <klarna-placement> element to your product
     template as a Custom Liquid block (see bottom of file).
  3. Paste THIS snippet immediately before </body> in
     theme.liquid.

  WHAT WAS WRONG IN v1:
  Klarna's index.js removes the placement element under two
  conditions:
    a) getLocale() returns null  — happens when storefrontCountry
       is not in Klarna's mid_locales list for your account.
       The store's mid_locales come from Klarna's own API
       (https://skosm.klarna.com/app-blocks/v1/store), NOT
       from the config object we push. So passing the wrong
       storefrontCountry / storefrontLanguage causes a null
       locale and instant removal.
    b) isDynamicPlacement() && !hasMatchingCurrency() — the
       data-key "credit-promotion-auto-size" is a dynamic
       placement, so Klarna cross-checks storefrontCurrency
       against localeToCurrency(storefrontCountry). The live
       app block was passing storefrontCurrency='USD' and
       storefrontCountry='US' (Shopify's server-side defaults
       when fetched without a session cookie), which caused a
       currency mismatch for UK visitors.

  THE FIX:
  - storefrontCountry and storefrontCurrency are now resolved
    client-side AFTER the page loads, using Klarna's own
    geolocation service (the same one index.js uses internally)
    and the Shopify.currency object that is always present on
    Shopify storefronts. This guarantees the values match what
    Klarna's API returns for the visitor's actual country.
  - The config push is deferred until after geolocation
    resolves, so klarnaAppBlocksManager always receives the
    correct values.
  - The Klarna JS is still lazy-loaded on scroll or after 3 s.
  ============================================================
{% endcomment %}

{% if template.name == 'product' %}

{%- assign klarna_variant_price = product.selected_or_first_available_variant.price -%}

<script>
(function () {
  'use strict';

  var KLARNA_JS_URL  = 'https://cdn.shopify.com/extensions/6da6ffdd-cf2b-4a18-80e5-578ff81399ca/klarna-on-site-messaging-33/assets/index.js';
  var GEOSERVICE_URL = 'https://skosm.klarna.com/geolocation/v1';
  var PLACEMENT_ID   = 'lb-klarna-placement';
  var VARIANT_PRICE  = {{ klarna_variant_price }};
  var SHOP_DOMAIN    = {{ shop.permanent_domain | json }};
  var SHOP_LOCALE    = {{ request.locale.iso_code | json }};
  var loaded         = false;

  /* ── Currency map (matches Klarna's internal localeToCurrency) ── */
  var COUNTRY_CURRENCY = {
    AU:'AUD', AT:'EUR', BE:'EUR', CA:'CAD', CZ:'CZK', DK:'DKK',
    FI:'EUR', FR:'EUR', DE:'EUR', GR:'EUR', HU:'HUF', IE:'EUR',
    IT:'EUR', MX:'MXN', NL:'EUR', NZ:'NZD', NO:'NOK', PL:'PLN',
    PT:'EUR', RO:'RON', SK:'EUR', ES:'EUR', SE:'SEK', CH:'CHF',
    GB:'GBP', US:'USD'
  };

  /* ── 1. Set up the manager queue before index.js loads ── */
  window.appBlockPlacements = window.appBlockPlacements || [];
  window.klarnaAppBlocksManager = window.klarnaAppBlocksManager || {
    _queue: [],
    push: function (cfg) { this._queue.push(cfg); }
  };

  /* ── 2. Resolve visitor country then push config ── */
  function pushKlarnaConfig(country) {
    var currency = COUNTRY_CURRENCY[country] || (window.Shopify && window.Shopify.currency && window.Shopify.currency.active) || 'GBP';
    var lang     = SHOP_LOCALE ? SHOP_LOCALE.slice(0, 2) : 'en';

    var cfg = {
      productVariants:     [],          /* empty — Klarna fetches from its CDN */
      templateName:        'product',
      dataKey:             'credit-promotion-auto-size',
      storefrontCurrency:  currency,
      storefrontCountry:   country,
      storefrontLanguage:  lang,
      shopLocale:          lang,
      shopDomain:          SHOP_DOMAIN,
      variantPrice:        String(VARIANT_PRICE),
      cartPrice:           '0',
      selector:            PLACEMENT_ID,
      topPadding:          '0',
      bottomPadding:       '0'
    };

    /* Push to queue — index.js will process it when it loads */
    window.appBlockPlacements.push(cfg);

    /* If index.js already loaded and created the real manager, push directly */
    if (window.klarnaAppBlocksManager && typeof window.klarnaAppBlocksManager.pushPlacement === 'function') {
      window.klarnaAppBlocksManager.pushPlacement(cfg);
    }
  }

  /* ── 3. Resolve country via Klarna's geolocation API ── */
  function resolveCountryAndPush() {
    var cached = null;
    try { cached = localStorage.getItem('klarnaosm_user_locale'); } catch(e) {}

    if (cached) {
      pushKlarnaConfig(cached);
      return;
    }

    var url = GEOSERVICE_URL + '?defaultDomain=' + encodeURIComponent(SHOP_DOMAIN) + '&customDomain=';
    var ctrl = typeof AbortController !== 'undefined' ? new AbortController() : null;
    var timer = ctrl ? setTimeout(function () { ctrl.abort(); }, 1500) : null;

    fetch(url, ctrl ? { signal: ctrl.signal } : {})
      .then(function (r) { return r.json(); })
      .then(function (data) {
        clearTimeout(timer);
        var country = (data && data.country) ? data.country : 'GB';
        try { localStorage.setItem('klarnaosm_user_locale', country); } catch(e) {}
        pushKlarnaConfig(country);
      })
      .catch(function () {
        /* Fallback: derive from timezone, default to GB */
        var tz = (Intl && Intl.DateTimeFormat) ? Intl.DateTimeFormat().resolvedOptions().timeZone : '';
        var TZ_MAP = {
          'Europe/London':'GB','Europe/Dublin':'IE','Europe/Paris':'FR',
          'Europe/Berlin':'DE','Europe/Amsterdam':'NL','Europe/Stockholm':'SE',
          'Europe/Oslo':'NO','Europe/Copenhagen':'DK','Europe/Helsinki':'FI',
          'Europe/Warsaw':'PL','Europe/Prague':'CZ','Europe/Budapest':'HU',
          'Europe/Bucharest':'RO','Europe/Bratislava':'SK','Europe/Vienna':'AT',
          'Europe/Brussels':'BE','Europe/Zurich':'CH','Europe/Lisbon':'PT',
          'Europe/Madrid':'ES','Europe/Rome':'IT','Europe/Athens':'GR',
          'America/New_York':'US','America/Chicago':'US','America/Denver':'US',
          'America/Los_Angeles':'US','America/Toronto':'CA','America/Vancouver':'CA',
          'Australia/Sydney':'AU','Pacific/Auckland':'NZ'
        };
        pushKlarnaConfig(TZ_MAP[tz] || 'GB');
      });
  }

  /* ── 4. Lazy-load the Klarna JS ── */
  function loadKlarnaScript() {
    if (loaded) return;
    loaded = true;
    var script   = document.createElement('script');
    script.src   = KLARNA_JS_URL;
    script.async = true;
    script.type  = 'text/javascript';
    /* When index.js loads it reads window.appBlockPlacements — already populated */
    document.head.appendChild(script);
  }

  /* Trigger on scroll-into-view OR after 3 s */
  var placement = document.getElementById(PLACEMENT_ID);
  if (placement && 'IntersectionObserver' in window) {
    var observer = new IntersectionObserver(function (entries) {
      if (entries[0].isIntersecting) {
        loadKlarnaScript();
        observer.disconnect();
      }
    }, { rootMargin: '200px' });
    observer.observe(placement);
  }
  setTimeout(loadKlarnaScript, 3000);

  /* ── 5. Resolve country and push config (runs immediately) ── */
  resolveCountryAndPush();

  /* ── 6. Update price on variant change ── */
  /* Dawn / most themes dispatch a native 'change' on the variant select/radio */
  document.addEventListener('change', function (e) {
    var t = e.target;
    if (!t || !t.form) return;
    if (!t.form.action || t.form.action.indexOf('/cart/add') === -1) return;
    var idInput = t.form.querySelector('[name="id"]');
    if (!idInput) return;
    fetchVariantPrice(parseInt(idInput.value, 10));
  });

  /* Some themes (e.g. Dawn) also fire a custom event */
  document.addEventListener('variant:changed', function (e) {
    if (e.detail && e.detail.variant) setKlarnaPrice(e.detail.variant.price);
  });
  document.addEventListener('variantChange', function (e) {
    if (e.detail && e.detail.variant) setKlarnaPrice(e.detail.variant.price);
  });

  function fetchVariantPrice(variantId) {
    fetch(window.location.pathname + '.json')
      .then(function (r) { return r.json(); })
      .then(function (data) {
        var variants = data.product && data.product.variants;
        if (!variants) return;
        for (var i = 0; i < variants.length; i++) {
          if (variants[i].id === variantId) { setKlarnaPrice(variants[i].price); break; }
        }
      })
      .catch(function () {});
  }

  function setKlarnaPrice(priceInCents) {
    var el = document.getElementById(PLACEMENT_ID);
    if (el) el.setAttribute('data-purchase-amount', String(priceInCents));
  }

})();
</script>

{% endif %}

{% comment %}
  ============================================================
  CUSTOM LIQUID BLOCK — add to product template
  ------------------------------------------------------------
  In the theme customiser, add a Custom Liquid block to your
  product template at the position where you want the Klarna
  instalment message to appear (below the price, above Add
  to Cart). Paste this exactly:

  <div id="shopify-block-klarna-lb" class="shopify-block shopify-app-block">
    <klarna-placement
      id="lb-klarna-placement"
      data-key="credit-promotion-auto-size"
      data-theme="custom"
      data-message-prefix=""
      data-integration-style="app-block">
    </klarna-placement>
  </div>

  The id="lb-klarna-placement" must match PLACEMENT_ID above.
  ============================================================
{% endcomment %}
