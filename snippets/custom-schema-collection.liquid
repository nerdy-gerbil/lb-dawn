<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "CollectionPage",
        "name": "{{ collection.title | replace: '&lt;', '<' | replace: '&gt;', '>' | replace: '&amp;', '&' | replace: '&#39;', "'" }}",
        "description": "{{ collection.description | strip_html | replace: '&lt;', '<' | replace: '&gt;', '>' | replace: '&amp;', '&' | replace: '&#39;', "'" }}",
        "url": "https://www.lilyblanche.com{{ collection.url }}",
        "image": "https:{{ collection.image | image_url }}",
        "isPartOf": {
          "@type": "WebSite",
          "name": "Lily Blanche",
          "url": "https://www.lilyblanche.com/"
        },
        "relatedLink": [
          "https://www.lilyblanche.com/pages/about-us",
          "https://www.lilyblanche.com/pages/contact-us"
        ],
        "mainEntity": {
          "@type": "ItemList",
          "itemListElement": [
            {% for collection_product in collection.products %}
              {
                {% render 'custom-schema-product-item',
                   product: collection_product,
                   part_of: 'collection'
                %}
              }{% unless forloop.last %},{% endunless %}
            {% endfor %}
          ]
        }
      }{% if shop.metaobjects.schema_shipping_policy.default %},
      {% assign shipping_json = shop.metaobjects.schema_shipping_policy.default.value %}

{
  "@id": "#shipping-policy",
  "@type": "OfferShippingDetails",

  "shippingRate": {
    "@type": "MonetaryAmount",
    "value": "0.00",
    "currency": "GBP"
  },

  "shippingDestination": {
    "@type": "DefinedRegion",
    "addressCountry": "GB"
  },

  "deliveryTime": {
    "@type": "ShippingDeliveryTime",
    "handlingTime": {
      "@type": "QuantitativeValue",
      "minValue": 1,
      "maxValue": 2,
      "unitCode": "DAY"
    },
    "transitTime": {
      "@type": "QuantitativeValue",
      "minValue": 2,
      "maxValue": 4,
      "unitCode": "DAY"
    }
  },

  "shippingSettings":
  {{ shipping_json.shippingSettings | json }}
}{% endif %}{% if shop.metaobjects.merchant_return_policy.values.size > 0 %}{% for policy in shop.metaobjects.merchant_return_policy.values %},
      {% assign return_policy_name = return_json | split: '"name"' | last | split: ',' | first | replace: ':', '' | replace: '"', '' | strip %}
      {% assign policy_name_downcase = return_policy_name | downcase %}
      {% if policy_name_downcase contains 'hygiene' or policy_name_downcase contains 'bespoke' %}
        {% assign category = 'https://schema.org/MerchantReturnNotPermitted' %}
      {% else %}
        {% assign category = 'https://schema.org/MerchantReturnFiniteReturnWindow' %}
      {% endif %}

      {% assign policy_handle = policy.system.handle | default: policy.handle %}
      {% if policy.id == shop.metaobjects.merchant_return_policy.default.id or policy_handle == 'default' or policy_handle == blank or shop.metaobjects.merchant_return_policy.values.size == 1 %}
        {% assign policy_id = '#return-policy' %}
      {% else %}
        {% assign policy_id = '#return-policy-' | append: policy_handle %}
      {% endif %}

      {% capture return_json_clean %}
      {
        "@id": "{{ policy_id }}",
        "@type": "MerchantReturnPolicy",
        "name": {{ return_policy_name | json }},
        "returnPolicyCategory": "{{ category }}"
      }
      {% endcapture %}
      {{ return_json_clean | strip_newlines | replace: '  ', '' }}
      {% endfor %}{% endif %}
    ]
  }
</script>
