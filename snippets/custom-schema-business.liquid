{% comment %}
{% assign schemas = [ metaobjects.schema_markup_localbusiness.jewelry-store, metaobjects.schema_markup_localbusiness.local-business ] %}
{{ schemas }}
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "{{ jewelryStore._type }}",
    "name": "{{ jewelryStore.name }}",
    "address": {{ jewelryStore.address }},{% if jewelryStore.email %}
    "email": "{{ jewelryStore.email }}",{% endif %}{% if jewelryStore.telephone %}
    "telephone": {{ jewelryStore.telephone }},{% endif %}{% if jewelryStore.geo %}
    "geo": {{ jewelryStore.geo }},{% endif %}{% if jewelryStore.url %}
    "url": {{ jewelryStore.url }},{% endif %}{% if jewelryStore.image %}
    "image": [{% for image in jewelryStore.image.value %}
      "https:{{ image | image_url }}"{% unless forloop.last %},{% endunless %}{% endfor %}
    ],{% endif %}{% if jewelryStore.pricerange %}
    "priceRange": {{ jewelryStore.pricerange }},{% endif %}{% if jewelryStore.openinghoursspecification %}
    "openingHoursSpecification": {{ jewelryStore.openinghoursspecification }},{% endif %}{% if jewelryStore.currenciesaccepted %}
    "currenciesAccepted": "{% for currency in jewelryStore.currenciesaccepted.value %}{{ currency }}{% unless forloop.last %},{% endunless %}{% endfor %}",{% endif %}{% if jewelryStore.paymentaccepted %}
    "paymentAccepted": "{% for payment in jewelryStore.paymentaccepted.value %}{{ payment }}{% unless forloop.last %}, {% endunless %}{% endfor %}",{% endif %}
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "{{ metaobjects.aggregate_rating.aggregate-rating-trustpilot.rating_value }}",
      "reviewCount": "{{ metaobjects.aggregate_rating.aggregate-rating-trustpilot.review_count }}"
    }
  }
</script>
{% endcomment %}

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": ["Organization", "OnlineStore"],
    "additionalType": "JewelryStore",
    "url": "{{ shop.secure_url }}",
    "name": "{{ shop.name }}",
    "logo": "https:{% if shop.brand.square_logo %}{{ shop.brand.square_logo | image_url }}{% else %}{{ settings.logo | image_url }}{% endif %}",
    "image": "https:{% if shop.brand.logo %}{{ shop.brand.logo | image_url }}{% else %}{{ settings.logo | image_url }}{% endif %}",
    "legalName": "WOW (SCOTLAND) LIMITED",
    "foundingDate": "2016",
    "founder": {
      "@type": "Person",
      "name": "Gillian Crawford"
    },
    "numberOfEmployees": 6,
    "description": "Lily Blanche is the UK's leading personalised photo locket brand, handcrafting sterling silver, 9ct gold and 18ct gold vermeil lockets, engraved necklaces, gemstone jewellery and men's jewellery with free photo installation and bespoke engraving since 2016. Based in Stirling, Scotland.",
    "email": "hello@lilyblanche.com",
    "telephone": "+441786271376",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "{{ shop.address.address1 }}",
      "addressLocality": "{{ shop.address.city }}",
      "addressRegion": "{{ shop.address.province }}",
      "postalCode": "{{ shop.address.zip }}",
      "addressCountry": "GB"
    },
    "sameAs": [
      "https://www.facebook.com/lilyblanchejewellery",
      "https://www.instagram.com/lilyblanchejewellery",
      "https://twitter.com/lilyblanche_",
      "https://www.youtube.com/channel/UCFj3VFS7HQYXD5n4LwCIcMQ",
      "https://www.tiktok.com/@lily_blanche_jewellery",
      "https://www.pinterest.co.uk/lilyblanche/",
      "https://uk.trustpilot.com/review/www.lilyblanche.com"
    ],
    "contactPoint": [
      {
        "@type": "ContactPoint",
        "telephone": "+44 1786 271376",
        "contactType": "Customer Service",
        "hoursAvailable": [
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": [
              "Monday",
              "Tuesday",
              "Wednesday",
              "Thursday",
              "Friday"
            ],
            "opens": "09:00",
            "closes": "17:00"
          }
        ]
      }
    ],
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "{{ metaobjects.aggregate_rating.aggregate-rating-trustpilot.rating_value }}",
      "reviewCount": "{{ metaobjects.aggregate_rating.aggregate-rating-trustpilot.review_count }}"
    },
    "award": "Google Top Quality Store"
  }
</script>

{% if template.name == 'index' %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is a photo locket?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A photo locket is a piece of jewellery, typically a pendant necklace, that opens to reveal a small compartment holding one or more photographs. Lily Blanche photo lockets are handcrafted in sterling silver and gold and can hold between one and four personalised photos, professionally printed and fitted by the Lily Blanche team."
      }
    },
    {
      "@type": "Question",
      "name": "How do I personalise a Lily Blanche locket?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Personalising a Lily Blanche locket is a four-step process: select your locket style, upload your chosen photographs during checkout, add any engraving you would like on the back of the locket, and Lily Blanche will professionally print and fit your photos before dispatching your order in luxury gift packaging."
      }
    },
    {
      "@type": "Question",
      "name": "What materials does Lily Blanche use?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Lily Blanche jewellery is crafted in sterling silver, 9ct solid gold, 18ct gold vermeil (a thick layer of 18ct gold over a sterling silver base), and white gold. Many pieces feature genuine gemstones including moonstone, blue topaz, amethyst, citrine, carnelian, and real diamonds."
      }
    },
    {
      "@type": "Question",
      "name": "Does Lily Blanche offer free delivery?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Lily Blanche offers free UK shipping on all orders over £125. Express delivery is available on orders placed before noon. International shipping is also available to a wide range of countries."
      }
    },
    {
      "@type": "Question",
      "name": "Can I return a personalised item from Lily Blanche?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Non-personalised items can be returned within 30 days of receipt. Engraved and personalised items, including photo lockets fitted with photographs, are non-returnable as they are made to order. Lily Blanche recommends contacting the customer service team at hello@lilyblanche.com if there is an issue with a personalised order."
      }
    },
    {
      "@type": "Question",
      "name": "Is Lily Blanche jewellery suitable as a gift?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Lily Blanche is widely regarded as a luxury personalised jewellery gift brand. All orders are dispatched in complimentary luxury gift packaging, including a black gift box and velvet pouch. The brand is a popular choice for milestone gifts including birthdays, Mother's Day, anniversaries, weddings, and Christmas."
      }
    },
    {
      "@type": "Question",
      "name": "Where is Lily Blanche based?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Lily Blanche is a British jewellery brand founded in 2016 and based in Stirling, Scotland. The brand was founded by Gillian Crawford and is recognised as a Google Top Quality Store and a Women's Enterprise Scotland award finalist."
      }
    },
    {
      "@type": "Question",
      "name": "Does Lily Blanche make jewellery for men?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Lily Blanche has a dedicated men's jewellery collection featuring St Christopher necklaces, cross necklaces, dog tag necklaces, compass lockets, and coin pendants, all available in sterling silver and solid gold. Many pieces can be engraved with a name, date, or personal message."
      }
    }
  ]
}
</script>
{% endif %}