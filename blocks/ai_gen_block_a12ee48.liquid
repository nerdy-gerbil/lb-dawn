    width: {{ block.settings.desktop_width_percent }}%;
  }

  .lb-compare-eyebrow-{{ ai_gen_id }} {
    font-size: {{ block.settings.eyebrow_size }}px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: {{ block.settings.eyebrow_color }};
    margin-bottom: 12px;
    display: block;
  }

  .lb-compare-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 400;
    color: {{ block.settings.title_color }};
    margin: 0 0 4px;
    line-height: 1.15;
  }

  .lb-compare-title-italic-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 400;
    font-style: italic;
    color: {{ block.settings.title_italic_color }};
    margin: 0 0 12px;
    display: block;
    line-height: 1.15;
  }

  .lb-compare-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0 0 32px;
  }

  .lb-compare-table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    border: 1px solid {{ block.settings.border_color }};
    background: {{ block.settings.table_bg_color }};
  }

  .lb-compare-table-{{ ai_gen_id }} th,
  .lb-compare-table-{{ ai_gen_id }} td {
    padding: {{ block.settings.cell_padding }}px {{ block.settings.cell_padding | times: 1.1 }}px;
    border: 1px solid {{ block.settings.border_color }};
    font-size: {{ block.settings.cell_text_size }}px;
    color: {{ block.settings.cell_text_color }};
    vertical-align: middle;
    line-height: 1.4;
  }

  .lb-compare-table-{{ ai_gen_id }} thead th {
    font-size: {{ block.settings.header_text_size }}px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: {{ block.settings.header_text_color }};
    background: {{ block.settings.header_bg_color }};
    text-align: center;
  }

  .lb-compare-table-{{ ai_gen_id }} thead th:first-child {
    background: {{ block.settings.header_bg_color }};
  }

  .lb-compare-table-{{ ai_gen_id }} thead th.lb-col-highlight-{{ ai_gen_id }} {
    background: {{ block.settings.highlight_header_bg }};
    color: {{ block.settings.highlight_header_text }};
  }

  .lb-compare-table-{{ ai_gen_id }} thead th.lb-col-highlight-{{ ai_gen_id }} small {
    display: block;
    font-size: {{ block.settings.header_text_size | times: 0.9 }}px;
    font-weight: 400;
    color: {{ block.settings.highlight_header_small_text }};
    text-transform: none;
    letter-spacing: 0.04em;
    margin-top: 4px;
  }

  .lb-compare-table-{{ ai_gen_id }} td:first-child {
    font-size: {{ block.settings.row_label_size }}px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: {{ block.settings.row_label_color }};
    background: {{ block.settings.row_label_bg }};
    width: {{ block.settings.row_label_width }}px;
  }

  .lb-compare-table-{{ ai_gen_id }} td.lb-col-highlight-{{ ai_gen_id }} {
    background: {{ block.settings.highlight_cell_bg }};
    font-weight: 600;
    color: {{ block.settings.highlight_cell_text }};
  }

  .lb-compare-table-{{ ai_gen_id }} td:not(:first-child) {
    text-align: center;
    color: {{ block.settings.cell_text_color }};
  }

  .lb-tick-{{ ai_gen_id }} {
    color: {{ block.settings.tick_color }};
    font-size: {{ block.settings.icon_size }}px;
    margin-right: 5px;
  }

  .lb-cross-{{ ai_gen_id }} {
    color: {{ block.settings.cross_color }};
    font-size: {{ block.settings.icon_size }}px;
    margin-right: 5px;
  }

  .lb-dash-{{ ai_gen_id }} {
    color: {{ block.settings.dash_color }};
    font-size: {{ block.settings.icon_size | times: 1.2 }}px;
    margin-right: 5px;
  }

  @media (max-width: 640px) {
    .lb-compare-scroll-{{ ai_gen_id }} {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
    .lb-compare-table-{{ ai_gen_id }} {
      min-width: 480px;
    }
    .lb-compare-table-{{ ai_gen_id }} th,
    .lb-compare-table-{{ ai_gen_id }} td {
      padding: 14px 12px;
      font-size: {{ block.settings.cell_text_size | times: 0.9 }}px;
    }
    .lb-compare-title-{{ ai_gen_id }},
    .lb-compare-title-italic-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
    }
  }
{% endstyle %}

