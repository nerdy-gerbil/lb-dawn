{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .lb-compare-wrap-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: {{ block.settings.top_margin }}px auto {{ block.settings.bottom_margin }}px;
    padding: 0 16px;
