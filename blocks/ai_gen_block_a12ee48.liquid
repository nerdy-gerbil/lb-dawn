{% schema %}
{
  "name": "Material comparison table",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "min": 600,
      "max": 1400,
      "step": 20,
      "unit": "px",
      "default": 860
    },
    {
      "type": "range",
      "id": "top_margin",
      "label": "Top margin",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "bottom_margin",
      "label": "Bottom margin",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Material Comparison"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Gold-plated vs Vermeil"
    },
    {
      "type": "text",
      "id": "title_italic",
      "label": "Title italic",
      "default": "vs Solid Gold"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Understanding your options before you buy."
    },
    {
      "type": "header",
      "content": "Column headers"
    },
    {
      "type": "text",
      "id": "col1_header",
      "label": "Column 1 header",
      "default": "Gold Plated"
    },
    {
      "type": "text",
      "id": "col2_header",
      "label": "Column 2 header (highlighted)",
      "default": "Lily Blanche Vermeil"
    },
    {
      "type": "text",
      "id": "col2_subheader",
      "label": "Column 2 subheader",
      "default": "Our standard"
    },
    {
      "type": "text",
      "id": "col3_header",
      "label": "Column 3 header",
      "default": "Solid Gold"
    },
    {
      "type": "header",
      "content": "Row 1"
    },
    {
      "type": "text",
      "id": "row1_label",
      "label": "Label",
      "default": "Base Metal"
    },
    {
      "type": "text",
      "id": "row1_col1",
      "label": "Column 1",
      "default": "Brass or copper"
    },
    {
      "type": "select",
      "id": "row1_col2_icon",
      "label": "Column 2 icon",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "tick", "label": "Tick ✓" },
        { "value": "cross", "label": "Cross ✗" },
        { "value": "dash", "label": "Dash –" }
      ],
      "default": "tick"
    },
    {
      "type": "text",
      "id": "row1_col2",
      "label": "Column 2",
      "default": "Sterling silver (925)"
    },
    {
      "type": "select",
      "id": "row1_col3_icon",
      "label": "Column 3 icon",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "tick", "label": "Tick ✓" },
        { "value": "cross", "label": "Cross ✗" },
        { "value": "dash", "label": "Dash –" }
      ],
      "default": "tick"
    },
    {
      "type": "text",
      "id": "row1_col3",
