{% doc %}
  @prompt
    create me a table that is editable with this code <!-- =====================================================
         LILY BLANCHE — Material Comparison Table
         Paste into a Custom HTML / Custom Liquid section
         in the Shopify Theme Editor on the Our Materials page
         ===================================================== -->
    
    <style>
      .lb-compare-wrap {
        max-width: 860px;
        margin: 48px auto;
        padding: 0 16px;
        font-family: inherit;
      }
    
      .lb-compare-eyebrow {
        font-size: 11px;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: #B8966A;
        margin-bottom: 12px;
        display: block;
      }
    
      .lb-compare-title {
        font-size: 36px;
        font-weight: 400;
        color: #000000;
        margin: 0 0 4px;
        line-height: 1.15;
      }
    
      .lb-compare-title-italic {
        font-size: 36px;
        font-weight: 400;
        font-style: italic;
        color: #B8966A;
        margin: 0 0 12px;
        display: block;
        line-height: 1.15;
      }
    
      .lb-compare-subtitle {
        font-size: 14px;
        color: #555555;
        margin: 0 0 32px;
      }
    
      /* ── TABLE ── */
      .lb-compare-table {
        width: 100%;
        border-collapse: collapse;
        border: 1px solid #E0D8CE;
        background: #ffffff;
      }
    
      .lb-compare-table th,
      .lb-compare-table td {
        padding: 18px 20px;
        border: 1px solid #E0D8CE;
        font-size: 13px;
        color: #000000;
        vertical-align: middle;
        line-height: 1.4;
      }
    
      /* Header row */
      .lb-compare-table thead th {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #000000;
        background: #F2EDE5;
        text-align: center;
      }
    
      .lb-compare-table thead th:first-child {
        background: #F2EDE5;
      }
    
      /* Highlighted centre column header */
      .lb-compare-table thead th.lb-col-highlight {
        background: #1C1A18;
        color: #ffffff;
      }
    
      .lb-compare-table thead th.lb-col-highlight small {
        display: block;
        font-size: 10px;
        font-weight: 400;
        color: #B8966A;
        text-transform: none;
        letter-spacing: 0.04em;
        margin-top: 4px;
      }
    
      /* Row label (first column) */
      .lb-compare-table td:first-child {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #000000;
        background: #F2EDE5;
        width: 140px;
      }
    
      /* Centre column cells */
      .lb-compare-table td.lb-col-highlight {
        background: #FAFAF8;
        font-weight: 600;
        color: #000000;
      }
    
      /* Other data cells */
      .lb-compare-table td:not(:first-child) {
        text-align: center;
        color: #333333;
      }
    
      /* Tick and cross */
      .lb-tick {
        color: #B8966A;
        font-size: 15px;
        margin-right: 5px;
      }
    
      .lb-cross {
        color: #BBBBBB;
        font-size: 15px;
        margin-right: 5px;
      }
    
      .lb-dash {
        color: #BBBBBB;
        font-size: 18px;
        margin-right: 5px;
      }
    
      /* Mobile: allow horizontal scroll */
      @media (max-width: 640px) {
        .lb-compare-scroll {
          overflow-x: auto;
          -webkit-overflow-scrolling: touch;
        }
        .lb-compare-table {
          min-width: 480px;
        }
        .lb-compare-table th,
        .lb-compare-table td {
          padding: 14px 12px;
          font-size: 12px;
        }
        .lb-compare-title,
        .lb-compare-title-italic {
          font-size: 26px;
        }
      }
    </style>
    
    <div class="lb-compare-wrap">
    
      <span class="lb-compare-eyebrow">Material Comparison</span>
      <h2 class="lb-compare-title">Gold-plated vs Vermeil</h2>
      <span class="lb-compare-title-italic">vs Solid Gold</span>
      <p class="lb-compare-subtitle">Understanding your options before you buy.</p>
    
      <div class="lb-compare-scroll">
