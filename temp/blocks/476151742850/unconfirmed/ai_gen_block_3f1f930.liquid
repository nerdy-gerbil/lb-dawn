{% doc %}
  @prompt
    add a full size image to the left of the table , can you fill the table in with all of the info below; UK SIZE	US SIZE	DIAMETER (mm)
    J	5	15.6
    J½		15.8
    K	5½	16
    K½		16.1
    L	6	16.4
    L½		16.6
    M	6½	16.8
    M½		17
    N	7	17.2
    N½		17.4
    O	7½	17.6
    O½		17.8
    P	8	18
    P½		18.2
    Q	8½	18.4
    R	9	18.8
    S	9½	19.2
    T	10	19.6
    U	10½	20
    V	11	20.4
    W	12	21.2
    Y	12½	21.6
    Z	13	21.8, make the image stick when scrolling to the bottom of the chart, the headers should also stick when scrolling
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-table-with-image-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-table-with-image__container-{{ ai_gen_id }} {
    display: flex;
    gap: 40px;
    align-items: flex-start;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-table-with-image__image-wrapper-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.image_width }}%;
    position: sticky;
    top: {{ block.settings.sticky_offset }}px;
    align-self: flex-start;
  }

  .ai-table-with-image__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-table-with-image__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
    position: relative;
  }

  .ai-table-with-image__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-table-with-image__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-table-with-image__table-wrapper-{{ ai_gen_id }} {
    flex: 1;
    overflow-x: auto;
  }

  .ai-table-with-image__table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    background-color: {{ block.settings.table_background_color }};
    border-radius: {{ block.settings.table_border_radius }}px;
    overflow: hidden;
  }

  .ai-table-with-image__table-{{ ai_gen_id }} thead {
    position: sticky;
    top: {{ block.settings.sticky_offset }}px;
    z-index: 10;
  }

  .ai-table-with-image__table-{{ ai_gen_id }} th {
    background-color: {{ block.settings.header_background_color }};
    color: {{ block.settings.header_text_color }};
    padding: {{ block.settings.cell_padding }}px;
    text-align: {{ block.settings.text_alignment }};
    font-weight: 600;
    font-size: {{ block.settings.header_font_size }}px;
    border-bottom: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
  }

  .ai-table-with-image__table-{{ ai_gen_id }} td {
    padding: {{ block.settings.cell_padding }}px;
    text-align: {{ block.settings.text_alignment }};
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_font_size }}px;
    border-bottom: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
  }

  .ai-table-with-image__table-{{ ai_gen_id }} tr:last-child td {
    border-bottom: none;
  }

  .ai-table-with-image__table-{{ ai_gen_id }} tbody tr:hover {
    background-color: {{ block.settings.row_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-table-with-image__container-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 24px;
    }

    .ai-table-with-image__image-wrapper-{{ ai_gen_id }} {
      flex: 0 0 100%;
      width: 100%;
      position: relative;
      top: auto;
    }

    .ai-table-with-image__table-wrapper-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-table-with-image__table-{{ ai_gen_id }} thead {
      top: 0;
    }
  }
{% endstyle %}

<table-with-image-{{ ai_gen_id }} class="ai-table-with-image-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-table-with-image__container-{{ ai_gen_id }}">
    <div class="ai-table-with-image__image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 1000 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
          class="ai-table-with-image__image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-table-with-image__image-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-table-with-image__empty-state-{{ ai_gen_id }}">
            Add an image
          </div>
        </div>
      {% endif %}
    </div>

    <div class="ai-table-with-image__table-wrapper-{{ ai_gen_id }}">
      <table class="ai-table-with-image__table-{{ ai_gen_id }}">
        <thead>
          <tr>
            <th>UK SIZE</th>
