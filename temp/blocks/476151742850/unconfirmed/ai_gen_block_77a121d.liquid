{% doc %}
  @prompt
    create me a table for a size chart
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-size-chart-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    overflow-x: auto;
  }

  .ai-size-chart-table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    background-color: {{ block.settings.table_background }};
    border: {{ block.settings.table_border_thickness }}px solid {{ block.settings.table_border_color }};
    border-radius: {{ block.settings.table_border_radius }}px;
    overflow: hidden;
  }

  .ai-size-chart-table-{{ ai_gen_id }} thead {
    background-color: {{ block.settings.header_background }};
  }

  .ai-size-chart-table-{{ ai_gen_id }} th {
    padding: {{ block.settings.cell_padding }}px;
    text-align: {{ block.settings.text_alignment }};
    font-weight: 600;
    color: {{ block.settings.header_text_color }};
    border-bottom: {{ block.settings.cell_border_thickness }}px solid {{ block.settings.cell_border_color }};
    font-size: {{ block.settings.header_font_size }}px;
  }

  .ai-size-chart-table-{{ ai_gen_id }} td {
    padding: {{ block.settings.cell_padding }}px;
    text-align: {{ block.settings.text_alignment }};
    color: {{ block.settings.body_text_color }};
    border-bottom: {{ block.settings.cell_border_thickness }}px solid {{ block.settings.cell_border_color }};
    font-size: {{ block.settings.body_font_size }}px;
  }

  .ai-size-chart-table-{{ ai_gen_id }} tbody tr:last-child td {
    border-bottom: none;
  }

  .ai-size-chart-table-{{ ai_gen_id }} tbody tr:nth-child(even) {
    background-color: {{ block.settings.row_alternate_background }};
  }

  .ai-size-chart-table-{{ ai_gen_id }} tbody tr:hover {
    background-color: {{ block.settings.row_hover_background }};
  }

  @media screen and (max-width: 749px) {
    .ai-size-chart-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-size-chart-table-{{ ai_gen_id }} th,
    .ai-size-chart-table-{{ ai_gen_id }} td {
      padding: {{ block.settings.cell_padding | times: 0.75 }}px;
      font-size: {{ block.settings.body_font_size | times: 0.9 }}px;
    }

    .ai-size-chart-table-{{ ai_gen_id }} th {
      font-size: {{ block.settings.header_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-size-chart-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <table class="ai-size-chart-table-{{ ai_gen_id }}">
    <thead>
      <tr>
        {% if block.settings.header_col_1 != blank %}
          <th>{{ block.settings.header_col_1 }}</th>
        {% endif %}
        {% if block.settings.header_col_2 != blank %}
          <th>{{ block.settings.header_col_2 }}</th>
        {% endif %}
        {% if block.settings.header_col_3 != blank %}
          <th>{{ block.settings.header_col_3 }}</th>
        {% endif %}
        {% if block.settings.header_col_4 != blank %}
          <th>{{ block.settings.header_col_4 }}</th>
        {% endif %}
        {% if block.settings.header_col_5 != blank %}
          <th>{{ block.settings.header_col_5 }}</th>
        {% endif %}
      </tr>
    </thead>
    <tbody>
      {% for i in (1..10) %}
        {% liquid
          assign row_col_1_key = 'row_' | append: i | append: '_col_1'
          assign row_col_2_key = 'row_' | append: i | append: '_col_2'
          assign row_col_3_key = 'row_' | append: i | append: '_col_3'
          assign row_col_4_key = 'row_' | append: i | append: '_col_4'
          assign row_col_5_key = 'row_' | append: i | append: '_col_5'

          assign row_col_1 = block.settings[row_col_1_key]
          assign row_col_2 = block.settings[row_col_2_key]
          assign row_col_3 = block.settings[row_col_3_key]
          assign row_col_4 = block.settings[row_col_4_key]
          assign row_col_5 = block.settings[row_col_5_key]
        %}

        {% if row_col_1 != blank or row_col_2 != blank or row_col_3 != blank or row_col_4 != blank or row_col_5 != blank %}
          <tr>
            {% if block.settings.header_col_1 != blank %}
              <td>{{ row_col_1 }}</td>
            {% endif %}
            {% if block.settings.header_col_2 != blank %}
              <td>{{ row_col_2 }}</td>
            {% endif %}
            {% if block.settings.header_col_3 != blank %}
              <td>{{ row_col_3 }}</td>
            {% endif %}
            {% if block.settings.header_col_4 != blank %}
              <td>{{ row_col_4 }}</td>
            {% endif %}
            {% if block.settings.header_col_5 != blank %}
              <td>{{ row_col_5 }}</td>
            {% endif %}
          </tr>
        {% endif %}
      {% endfor %}
    </tbody>
  </table>
</div>

