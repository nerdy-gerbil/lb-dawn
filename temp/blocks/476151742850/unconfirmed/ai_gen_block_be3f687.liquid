{% doc %}
  @prompt
    add a full size image to the left of the table 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-table-with-image-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-table-with-image__container-{{ ai_gen_id }} {
    display: flex;
    gap: 40px;
    align-items: flex-start;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-table-with-image__image-wrapper-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.image_width }}%;
    position: relative;
  }

  .ai-table-with-image__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-table-with-image__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
    position: relative;
  }

  .ai-table-with-image__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-table-with-image__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-table-with-image__table-wrapper-{{ ai_gen_id }} {
    flex: 1;
    overflow-x: auto;
  }

  .ai-table-with-image__table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    background-color: {{ block.settings.table_background_color }};
    border-radius: {{ block.settings.table_border_radius }}px;
    overflow: hidden;
  }

  .ai-table-with-image__table-{{ ai_gen_id }} th {
    background-color: {{ block.settings.header_background_color }};
    color: {{ block.settings.header_text_color }};
    padding: {{ block.settings.cell_padding }}px;
    text-align: {{ block.settings.text_alignment }};
    font-weight: 600;
    font-size: {{ block.settings.header_font_size }}px;
    border-bottom: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
  }

  .ai-table-with-image__table-{{ ai_gen_id }} td {
    padding: {{ block.settings.cell_padding }}px;
    text-align: {{ block.settings.text_alignment }};
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_font_size }}px;
    border-bottom: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
  }

  .ai-table-with-image__table-{{ ai_gen_id }} tr:last-child td {
    border-bottom: none;
  }

  .ai-table-with-image__table-{{ ai_gen_id }} tbody tr:hover {
    background-color: {{ block.settings.row_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-table-with-image__container-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 24px;
    }

    .ai-table-with-image__image-wrapper-{{ ai_gen_id }} {
      flex: 0 0 100%;
      width: 100%;
    }

    .ai-table-with-image__table-wrapper-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<table-with-image-{{ ai_gen_id }} class="ai-table-with-image-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-table-with-image__container-{{ ai_gen_id }}">
    <div class="ai-table-with-image__image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 1000 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
          class="ai-table-with-image__image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-table-with-image__image-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-table-with-image__empty-state-{{ ai_gen_id }}">
            Add an image
          </div>
        </div>
      {% endif %}
    </div>

    <div class="ai-table-with-image__table-wrapper-{{ ai_gen_id }}">
      <table class="ai-table-with-image__table-{{ ai_gen_id }}">
        <thead>
          <tr>
            {% if block.settings.column_1_header != blank %}
              <th>{{ block.settings.column_1_header }}</th>
            {% endif %}
            {% if block.settings.column_2_header != blank %}
              <th>{{ block.settings.column_2_header }}</th>
            {% endif %}
            {% if block.settings.column_3_header != blank %}
              <th>{{ block.settings.column_3_header }}</th>
            {% endif %}
            {% if block.settings.column_4_header != blank %}
              <th>{{ block.settings.column_4_header }}</th>
            {% endif %}
          </tr>
        </thead>
        <tbody>
          {% for i in (1..10) %}
            {% liquid
              assign row_col_1_key = 'row_' | append: i | append: '_col_1'
              assign row_col_2_key = 'row_' | append: i | append: '_col_2'
              assign row_col_3_key = 'row_' | append: i | append: '_col_3'
              assign row_col_4_key = 'row_' | append: i | append: '_col_4'
              
              assign col_1_value = block.settings[row_col_1_key]
              assign col_2_value = block.settings[row_col_2_key]
              assign col_3_value = block.settings[row_col_3_key]
              assign col_4_value = block.settings[row_col_4_key]
            %}
            
            {% if col_1_value != blank or col_2_value != blank or col_3_value != blank or col_4_value != blank %}
              <tr>
                {% if block.settings.column_1_header != blank %}
                  <td>{{ col_1_value }}</td>
                {% endif %}
                {% if block.settings.column_2_header != blank %}
                  <td>{{ col_2_value }}</td>
                {% endif %}
                {% if block.settings.column_3_header != blank %}
                  <td>{{ col_3_value }}</td>
                {% endif %}
                {% if block.settings.column_4_header != blank %}
                  <td>{{ col_4_value }}</td>
                {% endif %}
              </tr>
            {% endif %}
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</table-with-image-{{ ai_gen_id }}>

<script>
  (function() {
    class TableWithImage{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('table-with-image-{{ ai_gen_id }}', TableWithImage{{ ai_gen_id }});
  })();
</script>

