{% doc %}
  @prompt
    create me a table with 5 rows and three columns. the middle coloum will need to be able to have an image inserted
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-table-container-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    overflow-x: auto;
  }

  .ai-table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    border: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
  }

  .ai-table-{{ ai_gen_id }} th,
  .ai-table-{{ ai_gen_id }} td {
    padding: {{ block.settings.cell_padding }}px;
    border: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
    text-align: {{ block.settings.text_alignment }};
    vertical-align: middle;
  }

  .ai-table-{{ ai_gen_id }} th {
    background-color: {{ block.settings.header_bg_color }};
    color: {{ block.settings.header_text_color }};
    font-weight: 600;
    font-size: {{ block.settings.header_font_size }}px;
  }

  .ai-table-{{ ai_gen_id }} td {
    background-color: {{ block.settings.cell_bg_color }};
    color: {{ block.settings.cell_text_color }};
    font-size: {{ block.settings.cell_font_size }}px;
  }

  .ai-table-{{ ai_gen_id }} tbody tr:nth-child(even) td {
    background-color: {{ block.settings.alternate_row_bg_color }};
  }

  .ai-table-image-cell-{{ ai_gen_id }} {
    width: {{ block.settings.image_column_width }}%;
  }

  .ai-table-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.image_max_width }}px;
    margin: 0 auto;
  }

  .ai-table-image-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-table-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1 / 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-table-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  @media screen and (max-width: 749px) {
    .ai-table-{{ ai_gen_id }} th,
    .ai-table-{{ ai_gen_id }} td {
      padding: {{ block.settings.cell_padding | times: 0.7 }}px;
      font-size: {{ block.settings.cell_font_size | times: 0.9 }}px;
    }

    .ai-table-{{ ai_gen_id }} th {
      font-size: {{ block.settings.header_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<table-block-{{ ai_gen_id }} class="ai-table-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <table class="ai-table-{{ ai_gen_id }}">
    {% if block.settings.show_header %}
      <thead>
        <tr>
          <th>{{ block.settings.header_col_1 }}</th>
          <th class="ai-table-image-cell-{{ ai_gen_id }}">{{ block.settings.header_col_2 }}</th>
          <th>{{ block.settings.header_col_3 }}</th>
        </tr>
      </thead>
    {% endif %}
    <tbody>
      {% for i in (1..5) %}
        {% liquid
          assign col1_key = 'row_' | append: i | append: '_col_1'
          assign col2_image_key = 'row_' | append: i | append: '_col_2_image'
          assign col3_key = 'row_' | append: i | append: '_col_3'

          assign col1_value = block.settings[col1_key]
          assign col2_image = block.settings[col2_image_key]
          assign col3_value = block.settings[col3_key]
        %}
        <tr>
          <td>{{ col1_value }}</td>
          <td class="ai-table-image-cell-{{ ai_gen_id }}">
            <div class="ai-table-image-wrapper-{{ ai_gen_id }}">
              {% if col2_image %}
                <img
                  src="{{ col2_image | image_url: width: 400 }}"
                  alt="{{ col2_image.alt | escape }}"
                  loading="lazy"
                  width="{{ col2_image.width }}"
                  height="{{ col2_image.height }}"
                >
              {% else %}
                <div class="ai-table-image-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
          </td>
          <td>{{ col3_value }}</td>
        </tr>
      {% endfor %}
    </tbody>
  </table>
</table-block-{{ ai_gen_id }}>

<script>
  (function() {
    class TableBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('table-block-{{ ai_gen_id }}', TableBlock{{ ai_gen_id }});
  })();
</script>

