{% doc %}
  @prompt
    Create a styled comparison table for the Our Materials page that compares jewellery materials. The table should have: a dark grey or black header row background with white text, bold text in the first column (labels like Base Metal, Gold Purity, etc.), bold text in the Lily Blanche Vermeil column, and a simple border on all cells. The table should compare materials like Sterling Silver, Gold Vermeil, Gold Filled, and Lily Blanche Vermeil across rows like Base Metal, Gold Purity, Thickness, Longevity, and Tarnish Resistance.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-materials-table-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    overflow-x: auto;
  }

  .ai-materials-table-{{ ai_gen_id }}__table {
    width: 100%;
    border-collapse: collapse;
    border: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
  }

  .ai-materials-table-{{ ai_gen_id }}__header-row {
    background-color: {{ block.settings.header_bg_color }};
  }

  .ai-materials-table-{{ ai_gen_id }}__header-cell {
    padding: {{ block.settings.cell_padding }}px;
    text-align: {{ block.settings.text_alignment }};
    color: {{ block.settings.header_text_color }};
    font-weight: bold;
    border: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
    font-size: {{ block.settings.header_font_size }}px;
  }

  .ai-materials-table-{{ ai_gen_id }}__body-row {
    background-color: {{ block.settings.row_bg_color }};
  }

  .ai-materials-table-{{ ai_gen_id }}__body-row:nth-child(even) {
    background-color: {{ block.settings.row_alt_bg_color }};
  }

  .ai-materials-table-{{ ai_gen_id }}__body-cell {
    padding: {{ block.settings.cell_padding }}px;
    text-align: {{ block.settings.text_alignment }};
    color: {{ block.settings.text_color }};
    border: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
    font-size: {{ block.settings.body_font_size }}px;
  }

  .ai-materials-table-{{ ai_gen_id }}__body-cell--label {
    font-weight: bold;
  }

  .ai-materials-table-{{ ai_gen_id }}__body-cell--highlight {
    font-weight: bold;
  }

  @media screen and (max-width: 749px) {
    .ai-materials-table-{{ ai_gen_id }}__header-cell,
    .ai-materials-table-{{ ai_gen_id }}__body-cell {
      font-size: {{ block.settings.header_font_size | times: 0.9 }}px;
      padding: {{ block.settings.cell_padding | times: 0.8 }}px;
    }
  }
{% endstyle %}

<materials-comparison-table-{{ ai_gen_id }} class="ai-materials-table-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <table class="ai-materials-table-{{ ai_gen_id }}__table">
    <thead>
      <tr class="ai-materials-table-{{ ai_gen_id }}__header-row">
        <th class="ai-materials-table-{{ ai_gen_id }}__header-cell">{{ block.settings.header_col_1 }}</th>
        <th class="ai-materials-table-{{ ai_gen_id }}__header-cell">{{ block.settings.header_col_2 }}</th>
        <th class="ai-materials-table-{{ ai_gen_id }}__header-cell">{{ block.settings.header_col_3 }}</th>
        <th class="ai-materials-table-{{ ai_gen_id }}__header-cell">{{ block.settings.header_col_4 }}</th>
        <th class="ai-materials-table-{{ ai_gen_id }}__header-cell">{{ block.settings.header_col_5 }}</th>
      </tr>
    </thead>
    <tbody>
      <tr class="ai-materials-table-{{ ai_gen_id }}__body-row">
        <td class="ai-materials-table-{{ ai_gen_id }}__body-cell ai-materials-table-{{ ai_gen_id }}__body-cell--label">{{ block.settings.row_1_label }}</td>
        <td class="ai-materials-table-{{ ai_gen_id }}__body-cell">{{ block.settings.row_1_col_2 }}</td>
        <td class="ai-materials-table-{{ ai_gen_id }}__body-cell">{{ block.settings.row_1_col_3 }}</td>
        <td class="ai-materials-table-{{ ai_gen_id }}__body-cell">{{ block.settings.row_1_col_4 }}</td>
        <td class="ai-materials-table-{{ ai_gen_id }}__body-cell ai-materials-table-{{ ai_gen_id }}__body-cell--highlight">{{ block.settings.row_1_col_5 }}</td>
      </tr>
      <tr class="ai-materials-table-{{ ai_gen_id }}__body-row">
        <td class="ai-materials-table-{{ ai_gen_id }}__body-cell ai-materials-table-{{ ai_gen_id }}__body-cell--label">{{ block.settings.row_2_label }}</td>
        <td class="ai-materials-table-{{ ai_gen_id }}__body-cell">{{ block.settings.row_2_col_2 }}</td>
        <td class="ai-materials-table-{{ ai_gen_id }}__body-cell">{{ block.settings.row_2_col_3 }}</td>
        <td class="ai-materials-table-{{ ai_gen_id }}__body-cell">{{ block.settings.row_2_col_4 }}</td>
        <td class="ai-materials-table-{{ ai_gen_id }}__body-cell ai-materials-table-{{ ai_gen_id }}__body-cell--highlight">{{ block.settings.row_2_col_5 }}</td>
      </tr>
      <tr class="ai-materials-table-{{ ai_gen_id }}__body-row">
        <td class="ai-materials-table-{{ ai_gen_id }}__body-cell ai-materials-table-{{ ai_gen_id }}__body-cell--label">{{ block.settings.row_3_label }}</td>
        <td class="ai-materials-table-{{ ai_gen_id }}__body-cell">{{ block.settings.row_3_col_2 }}</td>
        <td class="ai-materials-table-{{ ai_gen_id }}__body-cell">{{ block.settings.row_3_col_3 }}</td>
        <td class="ai-materials-table-{{ ai_gen_id }}__body-cell">{{ block.settings.row_3_col_4 }}</td>
        <td class="ai-materials-table-{{ ai_gen_id }}__body-cell ai-materials-table-{{ ai_gen_id }}__body-cell--highlight">{{ block.settings.row_3_col_5 }}</td>
      </tr>
      <tr class="ai-materials-table-{{ ai_gen_id }}__body-row">
        <td class="ai-materials-table-{{ ai_gen_id }}__body-cell ai-materials-table-{{ ai_gen_id }}__body-cell--label">{{ block.settings.row_4_label }}</td>
        <td class="ai-materials-table-{{ ai_gen_id }}__body-cell">{{ block.settings.row_4_col_2 }}</td>
        <td class="ai-materials-table-{{ ai_gen_id }}__body-cell">{{ block.settings.row_4_col_3 }}</td>
        <td class="ai-materials-table-{{ ai_gen_id }}__body-cell">{{ block.settings.row_4_col_4 }}</td>
        <td class="ai-materials-table-{{ ai_gen_id }}__body-cell ai-materials-table-{{ ai_gen_id }}__body-cell--highlight">{{ block.settings.row_4_col_5 }}</td>
      </tr>
      <tr class="ai-materials-table-{{ ai_gen_id }}__body-row">
        <td class="ai-materials-table-{{ ai_gen_id }}__body-cell ai-materials-table-{{ ai_gen_id }}__body-cell--label">{{ block.settings.row_5_label }}</td>
        <td class="ai-materials-table-{{ ai_gen_id }}__body-cell">{{ block.settings.row_5_col_2 }}</td>
        <td class="ai-materials-table-{{ ai_gen_id }}__body-cell">{{ block.settings.row_5_col_3 }}</td>
        <td class="ai-materials-table-{{ ai_gen_id }}__body-cell">{{ block.settings.row_5_col_4 }}</td>
        <td class="ai-materials-table-{{ ai_gen_id }}__body-cell ai-materials-table-{{ ai_gen_id }}__body-cell--highlight">{{ block.settings.row_5_col_5 }}</td>
      </tr>
    </tbody>
  </table>
</materials-comparison-table-{{ ai_gen_id }}>

<script>
  (function() {
    class MaterialsComparisonTable{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('materials-comparison-table-{{ ai_gen_id }}', MaterialsComparisonTable{{ ai_gen_id }});
  })();
</script>

