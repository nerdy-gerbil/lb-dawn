{% doc %}
  @prompt
    Add a new custom content card block for a Men's Jewellery collection product grid, positioned after the 3rd product (grid position 4). The card should be the same size as a product card and have the following design:
    
    - Background: dark charcoal (#1C1C1A) with a subtle gold radial gradient overlay (using gold tones around #B89A5A, low opacity, emanating from the centre or bottom)
    - Watermark: the word "Dad" in large, faint, italic text in the top-right corner, in gold (#B89A5A) at very low opacity (around 5–10%), acting as a decorative background element
    - Content layout: text and button pinned to the bottom of the card
      - Eyebrow text: "FATHER'S DAY · 15 JUNE" in small uppercase letters, in gold (#B89A5A)
      - Headline: "The gift he'll wear every day" in white, elegant serif font
      - Button: "Shop Father's Day →" linking to /collections/fathers-day-jewellery, with a gold (#B89A5A) background and dark charcoal (#1C1C1A) text
    - The card should visually match the dimensions and grid behaviour of surrounding product cards, this should be included in the product grid after the 3rd product and should be the same size as the product card
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-fathers-day-card-{{ ai_gen_id }} {
    display: block;
    position: relative;
    background-color: {{ block.settings.background_color }};
    overflow: hidden;
    height: 100%;
    width: 100%;
    min-height: 400px;
    aspect-ratio: {{ block.settings.card_aspect_ratio }};
  }

  .ai-fathers-day-card-background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(
      circle at {{ block.settings.gradient_position }},
      {{ block.settings.gradient_color | color_modify: 'alpha', block.settings.gradient_opacity }},
      transparent 70%
    );
    pointer-events: none;
  }

  .ai-fathers-day-card-watermark-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.watermark_top }}%;
    right: {{ block.settings.watermark_right }}%;
    font-size: {{ block.settings.watermark_size }}px;
    font-style: italic;
    color: {{ block.settings.watermark_color }};
    opacity: {{ block.settings.watermark_opacity }};
    font-weight: 700;
    line-height: 1;
    pointer-events: none;
    user-select: none;
    transform: translate(25%, -25%);
  }

  .ai-fathers-day-card-content-{{ ai_gen_id }} {
    position: relative;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: {{ block.settings.content_padding }}px;
    z-index: 1;
  }

  .ai-fathers-day-card-eyebrow-{{ ai_gen_id }} {
    font-size: {{ block.settings.eyebrow_size }}px;
    color: {{ block.settings.eyebrow_color }};
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 12px;
    font-weight: 500;
  }

  .ai-fathers-day-card-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size }}px;
    color: {{ block.settings.headline_color }};
    font-family: {{ block.settings.headline_font.family }}, {{ block.settings.headline_font.fallback_families }};
    font-weight: {{ block.settings.headline_font.weight }};
    font-style: {{ block.settings.headline_font.style }};
    line-height: 1.2;
    margin-bottom: 20px;
  }

  .ai-fathers-day-card-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 500;
    border-radius: {{ block.settings.button_border_radius }}px;
    transition: all 0.3s ease;
    align-self: flex-start;
  }

  .ai-fathers-day-card-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-fathers-day-card-{{ ai_gen_id }} {
      min-height: 300px;
    }

    .ai-fathers-day-card-watermark-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.watermark_size }}px * 0.6);
    }

    .ai-fathers-day-card-headline-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.headline_size }}px * 0.8);
    }

    .ai-fathers-day-card-eyebrow-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.eyebrow_size }}px * 0.9);
    }
  }
{% endstyle %}

<fathers-day-card-{{ ai_gen_id }} class="ai-fathers-day-card-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-fathers-day-card-background-{{ ai_gen_id }}"></div>
  
  {% if block.settings.show_watermark %}
    <div class="ai-fathers-day-card-watermark-{{ ai_gen_id }}">
      {{ block.settings.watermark_text }}
    </div>
  {% endif %}

  <div class="ai-fathers-day-card-content-{{ ai_gen_id }}">
    {% if block.settings.eyebrow_text != blank %}
      <div class="ai-fathers-day-card-eyebrow-{{ ai_gen_id }}">
        {{ block.settings.eyebrow_text }}
      </div>
    {% endif %}

    {% if block.settings.headline_text != blank %}
      <h3 class="ai-fathers-day-card-headline-{{ ai_gen_id }}">
        {{ block.settings.headline_text }}
      </h3>
    {% endif %}

    {% if block.settings.button_text != blank %}
      <a 
        href="{{ block.settings.button_link }}" 
        class="ai-fathers-day-card-button-{{ ai_gen_id }}"
      >
        {{ block.settings.button_text }}
      </a>
    {% endif %}
  </div>
</fathers-day-card-{{ ai_gen_id }}>

<script>
  (function() {
    class FathersDayCard{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('fathers-day-card-{{ ai_gen_id }}', FathersDayCard{{ ai_gen_id }});
  })();
</script>

