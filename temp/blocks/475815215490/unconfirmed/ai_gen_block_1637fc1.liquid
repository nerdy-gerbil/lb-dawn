{% doc %}
  @prompt
    Create an enhanced Merchandising Block for a product grid with the following customisable settings in the Shopify theme editor sidebar:
    
    1. Font selector - a font_picker setting that allows the merchant to choose the font family for the heading and body text
    2. Subtitle field - a text input for a secondary line of text (subheading) displayed below the main heading
    3. Text position control - a select dropdown with options: Top Left, Top Centre, Top Right, Middle Left, Middle Centre, Middle Right, Bottom Left, Bottom Centre, Bottom Right - controlling where the text content sits within the card
    
    The block should also include the existing Merchandising Block features: background colour, heading text and colour, body text and colour, optional background image, and a button with label, link and colour. All controls should be intuitive for non-technical merchants to use in the theme editor., how do i implement this on my existing merchandising block
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-merchandising-block-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    min-height: 400px;
    background-color: {{ block.settings.background_color }};
    border-radius: 0;
    overflow: hidden;
    display: block;
  }

  .ai-merchandising-block__background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-merchandising-block__background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-merchandising-block__content-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    width: 100%;
    height: 100%;
    min-height: 400px;
    display: flex;
    padding: 40px;
    {% if block.settings.text_position == 'top_left' %}
      align-items: flex-start;
      justify-content: flex-start;
    {% elsif block.settings.text_position == 'top_center' %}
      align-items: flex-start;
      justify-content: center;
    {% elsif block.settings.text_position == 'top_right' %}
      align-items: flex-start;
      justify-content: flex-end;
    {% elsif block.settings.text_position == 'middle_left' %}
      align-items: center;
      justify-content: flex-start;
    {% elsif block.settings.text_position == 'middle_center' %}
      align-items: center;
      justify-content: center;
    {% elsif block.settings.text_position == 'middle_right' %}
      align-items: center;
      justify-content: flex-end;
    {% elsif block.settings.text_position == 'bottom_left' %}
      align-items: flex-end;
      justify-content: flex-start;
    {% elsif block.settings.text_position == 'bottom_center' %}
      align-items: flex-end;
      justify-content: center;
    {% elsif block.settings.text_position == 'bottom_right' %}
      align-items: flex-end;
      justify-content: flex-end;
    {% endif %}
  }

  .ai-merchandising-block__text-wrapper-{{ ai_gen_id }} {
    max-width: 600px;
    {% if block.settings.text_position contains 'center' %}
      text-align: center;
    {% elsif block.settings.text_position contains 'right' %}
      text-align: right;
    {% else %}
      text-align: left;
    {% endif %}
  }

  .ai-merchandising-block__heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
    color: {{ block.settings.heading_color }};
    font-size: 36px;
    line-height: 1.2;
    margin: 0 0 12px 0;
  }

  .ai-merchandising-block__subtitle-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-style: {{ block.settings.body_font.style }};
    color: {{ block.settings.body_color }};
    font-size: 18px;
    line-height: 1.4;
    margin: 0 0 16px 0;
  }

  .ai-merchandising-block__body-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-style: {{ block.settings.body_font.style }};
    color: {{ block.settings.body_color }};
    font-size: 16px;
    line-height: 1.6;
    margin: 0 0 24px 0;
  }

  .ai-merchandising-block__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 14px 32px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: 0;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-size: 16px;
    font-weight: 500;
    transition: opacity 0.3s ease;
    border: 1px solid {{ block.settings.button_color }};
  }

  .ai-merchandising-block__button-{{ ai_gen_id }}:hover {
    opacity: 0.85;
  }

  @media screen and (max-width: 749px) {
    .ai-merchandising-block-{{ ai_gen_id }} {
      min-height: 300px;
    }

    .ai-merchandising-block__content-{{ ai_gen_id }} {
      min-height: 300px;
      padding: 24px;
    }

    .ai-merchandising-block__heading-{{ ai_gen_id }} {
      font-size: 28px;
    }

    .ai-merchandising-block__subtitle-{{ ai_gen_id }} {
      font-size: 16px;
    }

    .ai-merchandising-block__body-{{ ai_gen_id }} {
      font-size: 14px;
    }
  }
{% endstyle %}

<div class="ai-merchandising-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.background_image %}
    <div class="ai-merchandising-block__background-{{ ai_gen_id }}">
      <img
        src="{{ block.settings.background_image | image_url: width: 2000 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
      >
    </div>
  {% endif %}

  <div class="ai-merchandising-block__content-{{ ai_gen_id }}">
    <div class="ai-merchandising-block__text-wrapper-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-merchandising-block__heading-{{ ai_gen_id }}">
          {{ block.settings.heading }}
        </h2>
      {% endif %}

      {% if block.settings.subtitle != blank %}
        <p class="ai-merchandising-block__subtitle-{{ ai_gen_id }}">
          {{ block.settings.subtitle }}
        </p>
      {% endif %}

      {% if block.settings.body_text != blank %}
        <div class="ai-merchandising-block__body-{{ ai_gen_id }}">
          {{ block.settings.body_text }}
        </div>
      {% endif %}

      {% if block.settings.button_label != blank and block.settings.button_link != blank %}
        <a
          href="{{ block.settings.button_link }}"
          class="ai-merchandising-block__button-{{ ai_gen_id }}"
        >
          {{ block.settings.button_label }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Merchandising block",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "select",
      "id": "text_position",
      "label": "Text position",
      "options": [
        {
          "value": "top_left",
          "label": "Top left"
        },
        {
          "value": "top_center",
          "label": "Top center"
        },
        {
          "value": "top_right",
          "label": "Top right"
        },
        {
          "value": "middle_left",
          "label": "Middle left"
        },
        {
          "value": "middle_center",
          "label": "Middle center"
        },
        {
          "value": "middle_right",
          "label": "Middle right"
        },
        {
          "value": "bottom_left",
          "label": "Bottom left"
        },
        {
          "value": "bottom_center",
          "label": "Bottom center"
        },
        {
          "value": "bottom_right",
          "label": "Bottom right"
        }
      ],
      "default": "middle_center"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#e6dfd7"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading font",
      "default": "sans-serif"
    },
    {
      "type": "font_picker",
      "id": "body_font",
      "label": "Body font",
      "default": "sans-serif"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading text",
      "default": "Featured collection"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Subtitle"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle text",
      "default": "Discover our latest arrivals"
    },
    {
      "type": "header",
      "content": "Body text"
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "Body text",
      "default": "<p>Explore our curated selection of premium products</p>"
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body text color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button background color",
      "default": "#6a2c32"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Merchandising block"
    }
  ]
}
{% endschema %}
