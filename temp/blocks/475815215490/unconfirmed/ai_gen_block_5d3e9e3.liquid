{% doc %}
  @prompt
    Create an enhanced Merchandising Block for a product grid with the following customisable settings in the Shopify theme editor sidebar:
    
    1. Font selector - a font_picker setting that allows the merchant to choose the font family for the heading and body text
    2. Subtitle field - a text input for a secondary line of text (subheading) displayed below the main heading
    3. Text position control - a select dropdown with options: Top Left, Top Centre, Top Right, Middle Left, Middle Centre, Middle Right, Bottom Left, Bottom Centre, Bottom Right - controlling where the text content sits within the card
    
    The block should also include the existing Merchandising Block features: background colour, heading text and colour, body text and colour, optional background image, and a button with label, link and colour. All controls should be intuitive for non-technical merchants to use in the theme editor.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-merch-block-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    min-height: 400px;
    background-color: {{ block.settings.background_color }};
    border-radius: 0;
    overflow: hidden;
    display: block;
  }

  .ai-merch-block-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 400px;
  }

  .ai-merch-block-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-merch-block-image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.background_color }};
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-merch-block-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
    opacity: 0.3;
  }

  .ai-merch-block-content-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 400px;
    padding: 40px;
    display: flex;
    z-index: 1;
    {% case block.settings.text_position %}
      {% when 'top_left' %}
        align-items: flex-start;
        justify-content: flex-start;
      {% when 'top_center' %}
        align-items: flex-start;
        justify-content: center;
      {% when 'top_right' %}
        align-items: flex-start;
        justify-content: flex-end;
      {% when 'middle_left' %}
        align-items: center;
        justify-content: flex-start;
      {% when 'middle_center' %}
        align-items: center;
        justify-content: center;
      {% when 'middle_right' %}
        align-items: center;
        justify-content: flex-end;
      {% when 'bottom_left' %}
        align-items: flex-end;
        justify-content: flex-start;
      {% when 'bottom_center' %}
        align-items: flex-end;
        justify-content: center;
      {% when 'bottom_right' %}
        align-items: flex-end;
        justify-content: flex-end;
    {% endcase %}
  }

  .ai-merch-block-text-wrapper-{{ ai_gen_id }} {
    max-width: 600px;
    {% if block.settings.text_position contains 'center' %}
      text-align: center;
    {% elsif block.settings.text_position contains 'right' %}
      text-align: right;
    {% else %}
      text-align: left;
    {% endif %}
  }

  .ai-merch-block-heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
    color: {{ block.settings.heading_color }};
    font-size: 36px;
    line-height: 1.2;
    margin: 0 0 12px 0;
  }

  .ai-merch-block-subtitle-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-style: {{ block.settings.body_font.style }};
    color: {{ block.settings.body_color }};
    font-size: 18px;
    line-height: 1.4;
    margin: 0 0 16px 0;
  }

  .ai-merch-block-body-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-style: {{ block.settings.body_font.style }};
    color: {{ block.settings.body_color }};
    font-size: 16px;
    line-height: 1.6;
    margin: 0 0 24px 0;
  }

  .ai-merch-block-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 14px 32px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: 0;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-size: 16px;
    transition: opacity 0.3s ease;
    border: 1px solid {{ block.settings.button_color }};
  }

  .ai-merch-block-button-{{ ai_gen_id }}:hover {
    opacity: 0.85;
  }

  @media screen and (max-width: 749px) {
    .ai-merch-block-{{ ai_gen_id }} {
      min-height: 300px;
    }

    .ai-merch-block-wrapper-{{ ai_gen_id }} {
      min-height: 300px;
    }

    .ai-merch-block-content-{{ ai_gen_id }} {
      min-height: 300px;
      padding: 24px;
    }

    .ai-merch-block-heading-{{ ai_gen_id }} {
      font-size: 28px;
    }

    .ai-merch-block-subtitle-{{ ai_gen_id }} {
      font-size: 16px;
    }

    .ai-merch-block-body-{{ ai_gen_id }} {
      font-size: 14px;
    }

    .ai-merch-block-button-{{ ai_gen_id }} {
      padding: 12px 24px;
      font-size: 14px;
    }
  }
{% endstyle %}

<merchandising-block-{{ ai_gen_id }} class="ai-merch-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-merch-block-wrapper-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2000 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
        class="ai-merch-block-image-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-merch-block-image-placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
      </div>
    {% endif %}

    <div class="ai-merch-block-content-{{ ai_gen_id }}">
      <div class="ai-merch-block-text-wrapper-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-merch-block-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}

        {% if block.settings.subtitle != blank %}
          <p class="ai-merch-block-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
        {% endif %}

        {% if block.settings.body_text != blank %}
          <div class="ai-merch-block-body-{{ ai_gen_id }}">{{ block.settings.body_text }}</div>
        {% endif %}

        {% if block.settings.button_label != blank and block.settings.button_link != blank %}
          <a href="{{ block.settings.button_link }}" class="ai-merch-block-button-{{ ai_gen_id }}">
            {{ block.settings.button_label }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</merchandising-block-{{ ai_gen_id }}>

{% schema %}
{
  "name": "Merchandising block",
  "settings": [
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading font",
      "default": "sans-serif"
    },
    {
      "type": "font_picker",
      "id": "body_font",
      "label": "Body font",
      "default": "sans-serif"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Collection"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#121212"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle"
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "Body text",
      "default": "<p>Discover our latest collection of handcrafted pieces</p>"
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body text color",
      "default": "#121212"
    },
    {
      "type": "select",
      "id": "text_position",
      "label": "Text position",
      "options": [
        {
          "value": "top_left",
          "label": "Top left"
        },
        {
          "value": "top_center",
          "label": "Top centre"
        },
        {
          "value": "top_right",
          "label": "Top right"
        },
        {
          "value": "middle_left",
          "label": "Middle left"
        },
        {
          "value": "middle_center",
          "label": "Middle centre"
        },
        {
          "value": "middle_right",
          "label": "Middle right"
        },
        {
          "value": "bottom_left",
          "label": "Bottom left"
        },
        {
          "value": "bottom_center",
          "label": "Bottom centre"
        },
        {
          "value": "bottom_right",
          "label": "Bottom right"
        }
      ],
      "default": "middle_center"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button color",
      "default": "#6a2c32"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#e6dfd7"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Merchandising block"
    }
  ],
  "tag": null
}
{% endschema %}
