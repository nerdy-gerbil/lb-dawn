{% doc %}
  @prompt
    create a design like this but make it fully editable <!-- =====================================================
         LILY BLANCHE — Gemstone Grid
         Paste into a Custom HTML / Custom Liquid section
         in the Shopify Theme Editor on the Our Materials page
         ===================================================== -->
    
    <style>
      .lb-gems-wrap {
        max-width: 860px;
        margin: 48px auto;
        padding: 0 16px;
        font-family: inherit;
      }
    
      .lb-gems-eyebrow {
        font-size: 11px;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: #B8966A;
        margin-bottom: 12px;
        display: block;
      }
    
      .lb-gems-title {
        font-size: 36px;
        font-weight: 400;
        color: #000000;
        margin: 0 0 4px;
        line-height: 1.15;
      }
    
      .lb-gems-title-italic {
        font-size: 36px;
        font-weight: 400;
        font-style: italic;
        color: #B8966A;
        margin: 0 0 12px;
        display: block;
        line-height: 1.15;
      }
    
      .lb-gems-subtitle {
        font-size: 14px;
        color: #555555;
        margin: 0 0 32px;
      }
    
      .lb-gems-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1px;
        background: #E0D8CE;
        border: 1px solid #E0D8CE;
      }
    
      .lb-gem-card {
        background: #FAF7F2;
        padding: 32px 28px;
      }
    
      .lb-gem-dot {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        margin-bottom: 16px;
        display: block;
      }
    
      .lb-gem-name {
        font-size: 24px;
        font-weight: 400;
        color: #000000;
        margin: 0 0 6px;
        display: block;
      }
    
      .lb-gem-meaning {
        font-size: 13px;
        font-style: italic;
        color: #7A7268;
        margin: 0 0 12px;
        display: block;
      }
    
      .lb-gem-desc {
        font-size: 14px;
        color: #333333;
        line-height: 1.65;
        margin: 0;
      }
    
      .lb-gem-desc a {
        color: #B8966A;
        text-decoration: underline;
        text-underline-offset: 3px;
      }
    
      /* Diamond callout box */
      .lb-gems-callout {
        margin-top: 2px;
        border: 1px solid #E0D8CE;
        border-top: none;
        padding: 24px 28px;
        background: #ffffff;
        display: flex;
        gap: 16px;
        align-items: flex-start;
      }
    
      .lb-gems-callout-icon {
        font-size: 20px;
        color: #B8966A;
        flex-shrink: 0;
        margin-top: 2px;
      }
    
      .lb-gems-callout p {
        font-size: 14px;
        color: #333333;
        line-height: 1.7;
        margin: 0;
      }
    
      .lb-gems-callout a {
        color: #B8966A;
        text-decoration: underline;
        text-underline-offset: 3px;
      }
    
      /* Mobile: single column */
      @media (max-width: 540px) {
        .lb-gems-grid {
          grid-template-columns: 1fr;
        }
        .lb-gems-title,
        .lb-gems-title-italic {
          font-size: 26px;
        }
      }
    </style>
    
    <div class="lb-gems-wrap">
    
      <span class="lb-gems-eyebrow">Natural Gemstones &amp; Diamonds</span>
      <h2 class="lb-gems-title">Ethically sourced.</h2>
      <span class="lb-gems-title-italic">Naturally beautiful.</span>
      <p class="lb-gems-subtitle">Every gemstone is natural, ethically sourced, and hand-set by our master craftspeople. No two are identical.</p>
    
      <div class="lb-gems-grid">
    
        <div class="lb-gem-card">
          <span class="lb-gem-dot" style="background: radial-gradient(circle at 35% 35%, #9B5FC0, #5B2D8E);"></span>
          <span class="lb-gem-name">Amethyst</span>
          <span class="lb-gem-meaning">Calmness &amp; Clarity</span>
          <p class="lb-gem-desc">February's <a href="https://www.lilyblanche.com/collections/february-birthstone">birthstone</a> — a deep, captivating purple with centuries of royal heritage.</p>
        </div>
    
        <div class="lb-gem-card">
          <span class="lb-gem-dot" style="background: radial-gradient(circle at 35% 35%, #E85A5A, #9B1A1A);"></span>
          <span class="lb-gem-name">Garnet</span>
          <span class="lb-gem-meaning">Passion &amp; Vitality</span>
          <p class="lb-gem-desc">January's <a href="https://www.lilyblanche.com/collections/january-birthstone">birthstone</a> — rich, warm reds that glow in any light.</p>
        </div>
    
        <div class="lb-gem-card">
          <span class="lb-gem-dot" style="background: radial-gradient(circle at 35% 35%, #5AACD4, #1A5C8A);"></span>
          <span class="lb-gem-name">Blue Topaz</span>
          <span class="lb-gem-meaning">Love &amp; Affection</span>
          <p class="lb-gem-desc">Cool, sky-blue tones with excellent brilliance and clarity.</p>
        </div>
    
        <div class="lb-gem-card">
          <span class="lb-gem-dot" style="background: radial-gradient(circle at 35% 35%, #3DB87A, #1A6B42);"></span>
          <span class="lb-gem-name">Emerald</span>
          <span class="lb-gem-meaning">Rebirth &amp; Prosperity</span>
          <p class="lb-gem-desc">Vivid greens of the highest quality — a gemstone of timeless elegance.</p>
        </div>
    
        <div class="lb-gem-card">
          <span class="lb-gem-dot" style="background: radial-gradient(circle at 35% 35%, #3A5FC0, #1A2D8E);"></span>
          <span class="lb-gem-name">Sapphire</span>
          <span class="lb-gem-meaning">Wisdom &amp; Nobility</span>
          <p class="lb-gem-desc">September's <a href="https://www.lilyblanche.com/collections/september-birthstone">
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-gemstone-grid-{{ ai_gen_id }} {
    display: block;
    max-width: {{ block.settings.max_width }}px;
    margin: {{ block.settings.section_spacing }}px auto;
    padding: 0 16px;
    font-family: inherit;
    width: {{ block.settings.desktop_width_percent }}%;
  }

  .ai-gemstone-eyebrow-{{ ai_gen_id }} {
    font-size: {{ block.settings.eyebrow_size }}px;
    letter-spacing: {{ block.settings.eyebrow_spacing }}em;
    text-transform: uppercase;
    color: {{ block.settings.eyebrow_color }};
    margin-bottom: {{ block.settings.eyebrow_margin }}px;
    display: block;
  }

  .ai-gemstone-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 400;
    color: {{ block.settings.title_color }};
    margin: 0 0 4px;
    line-height: 1.15;
  }

  .ai-gemstone-title-italic-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 400;
    font-style: italic;
    color: {{ block.settings.title_italic_color }};
    margin: 0 0 {{ block.settings.title_margin }}px;
    display: block;
    line-height: 1.15;
  }

  .ai-gemstone-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0 0 {{ block.settings.subtitle_margin }}px;
  }

  .ai-gemstone-grid-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    background: {{ block.settings.grid_border_color }};
    border: {{ block.settings.grid_gap }}px solid {{ block.settings.grid_border_color }};
  }

  .ai-gem-card-{{ ai_gen_id }} {
    background: {{ block.settings.card_bg_color }};
    padding: {{ block.settings.card_padding }}px {{ block.settings.card_padding_horizontal }}px;
  }

  .ai-gem-dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    margin-bottom: {{ block.settings.dot_margin }}px;
    display: block;
  }

  .ai-gem-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.gem_name_size }}px;
    font-weight: 400;
    color: {{ block.settings.gem_name_color }};
    margin: 0 0 6px;
    display: block;
  }

  .ai-gem-meaning-{{ ai_gen_id }} {
    font-size: {{ block.settings.gem_meaning_size }}px;
    font-style: italic;
    color: {{ block.settings.gem_meaning_color }};
    margin: 0 0 {{ block.settings.gem_meaning_margin }}px;
    display: block;
  }

  .ai-gem-desc-{{ ai_gen_id }} {
    font-size: {{ block.settings.gem_desc_size }}px;
    color: {{ block.settings.gem_desc_color }};
    line-height: 1.65;
    margin: 0;
  }

  .ai-gem-desc-{{ ai_gen_id }} a {
    color: {{ block.settings.link_color }};
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .ai-gemstone-callout-{{ ai_gen_id }} {
    margin-top: 2px;
    border: {{ block.settings.grid_gap }}px solid {{ block.settings.grid_border_color }};
    border-top: none;
    padding: {{ block.settings.callout_padding }}px {{ block.settings.card_padding_horizontal }}px;
    background: {{ block.settings.callout_bg_color }};
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .ai-gemstone-callout-icon-{{ ai_gen_id }} {
    font-size: {{ block.settings.callout_icon_size }}px;
    color: {{ block.settings.callout_icon_color }};
    flex-shrink: 0;
    margin-top: 2px;
  }

  .ai-gemstone-callout-{{ ai_gen_id }} p {
    font-size: {{ block.settings.callout_text_size }}px;
    color: {{ block.settings.callout_text_color }};
    line-height: 1.7;
    margin: 0;
  }

  .ai-gemstone-callout-{{ ai_gen_id }} a {
    color: {{ block.settings.link_color }};
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (max-width: 749px) {
    .ai-gemstone-grid-container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }
    .ai-gemstone-title-{{ ai_gen_id }},
    .ai-gemstone-title-italic-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size_mobile }}px;
    }
  }
{% endstyle %}

<gemstone-grid-{{ ai_gen_id }} class="ai-gemstone-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.eyebrow != blank %}
    <span class="ai-gemstone-eyebrow-{{ ai_gen_id }}">{{ block.settings.eyebrow }}</span>
  {% endif %}

  {% if block.settings.title != blank %}
    <h2 class="ai-gemstone-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
  {% endif %}

  {% if block.settings.title_italic != blank %}
    <span class="ai-gemstone-title-italic-{{ ai_gen_id }}">{{ block.settings.title_italic }}</span>
  {% endif %}

  {% if block.settings.subtitle != blank %}
    <div class="ai-gemstone-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</div>
  {% endif %}

  <div class="ai-gemstone-grid-container-{{ ai_gen_id }}">
    {% for i in (1..6) %}
      {% liquid
        assign gem_enabled_key = 'gem_' | append: i | append: '_enabled'
        assign gem_name_key = 'gem_' | append: i | append: '_name'
        assign gem_meaning_key = 'gem_' | append: i | append: '_meaning'
        assign gem_desc_key = 'gem_' | append: i | append: '_description'
        assign gem_color_key = 'gem_' | append: i | append: '_color'

        assign gem_enabled = block.settings[gem_enabled_key]
        assign gem_name = block.settings[gem_name_key]
        assign gem_meaning = block.settings[gem_meaning_key]
        assign gem_desc = block.settings[gem_desc_key]
        assign gem_color = block.settings[gem_color_key]
      %}

      {% if gem_enabled %}
        <div class="ai-gem-card-{{ ai_gen_id }}">
          <span class="ai-gem-dot-{{ ai_gen_id }}" style="background: {{ gem_color }};"></span>
          {% if gem_name != blank %}
            <span class="ai-gem-name-{{ ai_gen_id }}">{{ gem_name }}</span>
          {% endif %}
          {% if gem_meaning != blank %}
            <span class="ai-gem-meaning-{{ ai_gen_id }}">{{ gem_meaning }}</span>
          {% endif %}
          {% if gem_desc != blank %}
            <div class="ai-gem-desc-{{ ai_gen_id }}">{{ gem_desc }}</div>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>

  {% if block.settings.show_callout %}
    <div class="ai-gemstone-callout-{{ ai_gen_id }}">
      {% if block.settings.callout_icon != blank %}
        <span class="ai-gemstone-callout-icon-{{ ai_gen_id }}">{{ block.settings.callout_icon }}</span>
      {% endif %}
      {% if block.settings.callout_text != blank %}
        <div>{{ block.settings.callout_text }}</div>
      {% endif %}
    </div>
  {% endif %}
</gemstone-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class GemstoneGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('gemstone-grid-{{ ai_gen_id }}', GemstoneGrid{{ ai_gen_id }});
  })();
</script>

