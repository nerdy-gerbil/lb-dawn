{% schema %}
{
  "name": "Ring size table",
  "settings": [
    {
      "type": "header",
      "content": "Table style"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "font_picker",
      "id": "font_family",
      "label": "Font",
      "default": "sans-serif"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Body font size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "header_font_size",
      "label": "Header font size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "range",
      "id": "cell_padding",
      "label": "Cell padding",
      "min": 8,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "header_background_color",
      "label": "Header background",
      "default": "#e6dfd7"
    },
    {
      "type": "color",
      "id": "header_text_color",
      "label": "Header text",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "row_alternate_color",
      "label": "Alternate row",
      "default": "#f9f7f5"
    },
    {
      "type": "color",
      "id": "row_hover_color",
      "label": "Row hover",
      "default": "#f0ebe5"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border",
      "default": "#e6dfd7"
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Border width",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "header",
      "content": "Note"
    },
    {
      "type": "textarea",
      "id": "note_text",
      "label": "Note text",
      "default": "EU sizes are based on inner circumference (mm) and Japan sizes follow the JIS numeric scale. As with all international conversions, these are close equivalents — if you're ordering from outside the UK, we recommend confirming with the millimetre diameter measurement for the most accurate fit."
    },
    {
      "type": "range",
      "id": "note_font_size",
      "label": "Note font size",
      "min": 10,
      "max": 16,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color",
      "id": "note_text_color",
      "label": "Note text color",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "note_spacing",
      "label": "Note spacing",
      "min": 8,
      "max": 32,
      "step": 4,
      "unit": "px",
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "Ring size table"
    }
  ]
}
{% endschema %}