{% doc %}
  @prompt
    Update the existing ring size table block to add two new columns: EU SIZE and JAPAN SIZE, positioned between the existing US SIZE and DIAMETER (mm) columns. The full updated table should contain these 5 columns: UK | US | EU | JAPAN | DIAMETER (mm) with rows: J|5|49|9|15.6, J½||50|9|15.8, K|5½|50|10|16.0, K½||51|10|16.1, L|6|52|11|16.4, L½||52|12|16.6, M|6½|53|12|16.8, M½||53|13|17.0, N|7|54|14|17.2, N½||55|14|17.4, O|7½|55|15|17.6, O½||56|15|17.8, P|8|57|16|18.0, P½||57|17|18.2, Q|8½|58|17|18.4, R|9|59|18|18.8, S|9½|60|20|19.2, T|10|62|21|19.6, U|10½|63|22|20.0, V|11|64|23|20.4, W|12|67|26|21.2, Y|12½|68|27|21.6, Z|13|68|27|21.8. Add this note below the table in smaller muted italic text: "EU sizes are based on inner circumference (mm) and Japan sizes follow the JIS numeric scale. As with all international conversions, these are close equivalents — if you're ordering from outside the UK, we recommend confirming with the millimetre diameter measurement for the most accurate fit." Style to match a clean, elegant jewellery brand aesthetic.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-ring-size-table-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: block;
  }

  .ai-ring-size-table__wrapper-{{ ai_gen_id }} {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .ai-ring-size-table__table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    font-family: {{ block.settings.font_family.family }}, {{ block.settings.font_family.fallback_families }};
    font-size: {{ block.settings.font_size }}px;
    color: {{ block.settings.text_color }};
    background-color: {{ block.settings.background_color }};
  }

  .ai-ring-size-table__table-{{ ai_gen_id }} th {
    background-color: {{ block.settings.header_background_color }};
    color: {{ block.settings.header_text_color }};
    font-weight: 600;
    text-align: left;
    padding: {{ block.settings.cell_padding }}px;
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    font-size: {{ block.settings.header_font_size }}px;
    letter-spacing: 0.5px;
  }

  .ai-ring-size-table__table-{{ ai_gen_id }} td {
    padding: {{ block.settings.cell_padding }}px;
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    text-align: left;
  }

  .ai-ring-size-table__table-{{ ai_gen_id }} tbody tr:nth-child(even) {
    background-color: {{ block.settings.row_alternate_color }};
  }

  .ai-ring-size-table__table-{{ ai_gen_id }} tbody tr:hover {
    background-color: {{ block.settings.row_hover_color }};
  }

  .ai-ring-size-table__note-{{ ai_gen_id }} {
    margin-top: {{ block.settings.note_spacing }}px;
    font-size: {{ block.settings.note_font_size }}px;
    color: {{ block.settings.note_text_color }};
    font-style: italic;
    line-height: 1.6;
    opacity: 0.85;
  }

  @media screen and (max-width: 749px) {
    .ai-ring-size-table__table-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.9 }}px;
    }

    .ai-ring-size-table__table-{{ ai_gen_id }} th {
      font-size: {{ block.settings.header_font_size | times: 0.9 }}px;
      padding: {{ block.settings.cell_padding | times: 0.8 }}px;
    }

    .ai-ring-size-table__table-{{ ai_gen_id }} td {
      padding: {{ block.settings.cell_padding | times: 0.8 }}px;
    }

    .ai-ring-size-table__note-{{ ai_gen_id }} {
      font-size: {{ block.settings.note_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-ring-size-table-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
