{% doc %}
  @prompt
    create me a two column table with this information Promise Category	Key Commitments
    Quality & Craftsmanship	100% precious metals (Solid Gold, Sterling Silver, Gold Vermeil), Edinburgh Assay Office hallmarking, ethically sourced natural gemstones, handcrafted by master artisans.
    Personalisation	Free photo service with lockets, bespoke engraving, dedicated customer support for customisation, Memory Keeper Lockets®.
    Sustainability	Net zero by 2050, biodegradable/reusable packaging (75% recycled), carbon offsetting, local UK suppliers, green delivery partnerships.
    Social Responsibility	Scottish Business Pledge signatory (Living Wage), support for Social Bite (homelessness), mentoring female entrepreneurs, local community engagement.
    Customer Experience	Transparent pricing, secure data handling, luxurious packaging, fast and reliable shipping, personalized care, 4.7/5 Trustpilot rating. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-promise-table-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-promise-table-wrapper-{{ ai_gen_id }} {
    overflow-x: auto;
    border: {{ block.settings.table_border_thickness }}px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-promise-table-element-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    background-color: {{ block.settings.background_color }};
  }

  .ai-promise-table-element-{{ ai_gen_id }} thead {
    background-color: {{ block.settings.header_background_color }};
  }

  .ai-promise-table-element-{{ ai_gen_id }} th {
    padding: {{ block.settings.cell_padding }}px;
    text-align: left;
    font-weight: 600;
    font-size: {{ block.settings.header_font_size }}px;
    color: {{ block.settings.header_text_color }};
    border-bottom: {{ block.settings.table_border_thickness }}px solid {{ block.settings.border_color }};
  }

  .ai-promise-table-element-{{ ai_gen_id }} td {
    padding: {{ block.settings.cell_padding }}px;
    font-size: {{ block.settings.body_font_size }}px;
    color: {{ block.settings.body_text_color }};
    border-bottom: {{ block.settings.table_border_thickness }}px solid {{ block.settings.border_color }};
    vertical-align: top;
  }

  .ai-promise-table-element-{{ ai_gen_id }} tbody tr:last-child td {
    border-bottom: none;
  }

  .ai-promise-table-element-{{ ai_gen_id }} td:first-child {
    font-weight: 600;
    width: {{ block.settings.first_column_width }}%;
  }

  .ai-promise-table-element-{{ ai_gen_id }} tbody tr:nth-child(even) {
    background-color: {{ block.settings.row_stripe_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-promise-table-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-promise-table-element-{{ ai_gen_id }} th,
    .ai-promise-table-element-{{ ai_gen_id }} td {
      font-size: {{ block.settings.body_font_size | times: 0.9 }}px;
      padding: {{ block.settings.cell_padding | times: 0.8 }}px;
    }

    .ai-promise-table-element-{{ ai_gen_id }} th {
      font-size: {{ block.settings.header_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<promise-table-{{ ai_gen_id }} class="ai-promise-table-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-promise-table-wrapper-{{ ai_gen_id }}">
    <table class="ai-promise-table-element-{{ ai_gen_id }}">
      <thead>
        <tr>
          <th>{{ block.settings.column_1_header }}</th>
          <th>{{ block.settings.column_2_header }}</th>
        </tr>
      </thead>
      <tbody>
        {% if block.settings.row_1_col_1 != blank or block.settings.row_1_col_2 != blank %}
          <tr>
            <td>{{ block.settings.row_1_col_1 }}</td>
            <td>{{ block.settings.row_1_col_2 }}</td>
          </tr>
        {% endif %}
        {% if block.settings.row_2_col_1 != blank or block.settings.row_2_col_2 != blank %}
          <tr>
            <td>{{ block.settings.row_2_col_1 }}</td>
            <td>{{ block.settings.row_2_col_2 }}</td>
          </tr>
        {% endif %}
        {% if block.settings.row_3_col_1 != blank or block.settings.row_3_col_2 != blank %}
          <tr>
            <td>{{ block.settings.row_3_col_1 }}</td>
            <td>{{ block.settings.row_3_col_2 }}</td>
          </tr>
        {% endif %}
        {% if block.settings.row_4_col_1 != blank or block.settings.row_4_col_2 != blank %}
          <tr>
            <td>{{ block.settings.row_4_col_1 }}</td>
            <td>{{ block.settings.row_4_col_2 }}</td>
          </tr>
        {% endif %}
        {% if block.settings.row_5_col_1 != blank or block.settings.row_5_col_2 != blank %}
          <tr>
            <td>{{ block.settings.row_5_col_1 }}</td>
            <td>{{ block.settings.row_5_col_2 }}</td>
          </tr>
        {% endif %}
      </tbody>
    </table>
  </div>
</promise-table-{{ ai_gen_id }}>

<script>
  (function() {
    class PromiseTable{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('promise-table-{{ ai_gen_id }}', PromiseTable{{ ai_gen_id }});
  })();
</script>

