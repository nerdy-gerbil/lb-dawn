{{ 'section-main-page.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="page-width page-width--narrow section-{{ section.id }}-padding">
  <h1 class="main-page-title page-title h0{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
    {{ page.title | escape }}
  </h1>
  <div class="rte{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
    {{ page.content }}
  </div>

  {%- for block in section.blocks -%}
    {%- case block.type -%}
      {%- when 'faq' -%}
        {{ 'component-accordion.css' | asset_url | stylesheet_tag }}
        {%- liquid
          assign has_faq_content = false
          for i in (1..9)
            assign q_key = "faq_question_" | append: i
            assign a_key = "faq_answer_" | append: i
            assign q = page.metafields.custom[q_key]
            assign a = page.metafields.custom[a_key]
            if q != blank and a != blank
              assign has_faq_content = true
              break
            endif
          endfor
        -%}
        {%- if has_faq_content -%}
          <div class="faq-widget" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <h2 class="faq-widget__heading h3 inline-richtext">{{ block.settings.heading }}</h2>
            {%- endif -%}
            {%- for i in (1..9) -%}
              {%- assign q_key = "faq_question_" | append: i -%}
              {%- assign a_key = "faq_answer_" | append: i -%}
              {%- assign q = page.metafields.custom[q_key] -%}
              {%- assign a = page.metafields.custom[a_key] -%}
              {%- if q != blank and a != blank -%}
                <div class="accordion">
                  <details id="Details-faq-{{ i }}-{{ section.id }}">
                    <summary id="Summary-faq-{{ i }}-{{ section.id }}">
                      <div class="accordion__title inline-richtext h4">
                        {{ q }}
                      </div>
                      {{- 'icon-caret.svg' | inline_asset_content -}}
                    </summary>
                    <div class="accordion__content rte" id="CollapsibleAccordion-faq-{{ i }}-{{ section.id }}" role="region" aria-labelledby="Summary-faq-{{ i }}-{{ section.id }}">
                      {{ a | metafield_tag }}
                    </div>
                  </details>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
    {%- endcase -%}
  {%- endfor -%}
</div>

{%- liquid
  assign has_faq = false
  for i in (1..9)
    assign q_key = "faq_question_" | append: i
    assign q = page.metafields.custom[q_key]
    if q != blank
      assign has_faq = true
      break
    endif
  endfor
-%}

{%- if has_faq -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- assign comma = false -%}
    {%- for i in (1..9) -%}
      {%- assign q_key = "faq_question_" | append: i -%}
      {%- assign a_key = "faq_answer_" | append: i -%}
      {%- assign q = page.metafields.custom[q_key] -%}
      {%- assign a = page.metafields.custom[a_key] -%}
      {%- if q != blank and a != blank -%}
        {%- if comma -%},{%- endif -%}
        {
          "@type": "Question",
          "name": {{ q | strip_html | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ a | metafield_tag | strip_html | json }}
          }
        }
        {%- assign comma = true -%}
      {%- endif -%}
    {%- endfor -%}
  ]
}
</script>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.main-page.name",
  "tag": "section",
  "class": "section",
  "blocks": [
    {
      "type": "faq",
      "name": "FAQs Accordion",
      "limit": 1,
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "Frequently Asked Questions",
          "label": "Heading"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}
