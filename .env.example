# Shopify Store Configuration
# Domain of your Shopify store (e.g. your-store.myshopify.com)
SHOPIFY_STORE_DOMAIN=lily-blanche-1727.myshopify.com

# Shopify App Credentials from Developer Dashboard (Client ID and Client Secret shpss_...)
SHOPIFY_CLIENT_ID=your_client_id_here
SHOPIFY_CLIENT_SECRET=shpss_your_client_secret_here

# Shopify Admin API Access Token (shpat_...)
# Obtained automatically by running: node scripts/get-token.js
# Requires read_apps access scope configured in Developer Dashboard
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_retrieved_token_here
