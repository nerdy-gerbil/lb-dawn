{% layout none %}{{ '<?xml version="1.0"?>' }}
<rss xmlns:g="http://base.google.com/ns/1.0" version="2.0">
  <channel>
    <title>{{ shop.name }} Conversational Feed</title>
    <link>{{ shop.url }}</link>
    <description>Supplemental feed for Google Merchant Center AI Shopping</description>
    {% paginate collections.all.products by 1000 %}
      {% for product in collections.all.products %}
        {% for variant in product.variants %}
          <item>
            <!-- ID must match primary feed ID. E.g., shopify_[Country]_[ProductID]_[VariantID] -->
            <g:id>{{ variant.sku | xml_escape | default: variant.id }}</g:id>
            
            <!-- 1. Question and Answer (Supports List of Strings or Newline-separated Text) -->
            {% if product.metafields.custom.faq_questions.value != blank %}
              {% if product.metafields.custom.faq_questions.type contains 'list' %}
                {% assign questions = product.metafields.custom.faq_questions.value %}
                {% assign answers = product.metafields.custom.faq_answers.value %}
              {% else %}
                {% capture newline %}
{% endcapture %}
                {% assign questions = product.metafields.custom.faq_questions.value | split: newline %}
                {% assign answers = product.metafields.custom.faq_answers.value | split: newline %}
              {% endif %}

              {% for question in questions %}
                {% assign clean_question = question | strip %}
                {% assign answer = answers[forloop.index0] | strip %}
                {% if clean_question != blank and answer != blank %}
                  <g:question_and_answer>
                    <g:question>{{ clean_question | xml_escape }}</g:question>
                    <g:answer>{{ answer | xml_escape }}</g:answer>
                  </g:question_and_answer>
                {% endif %}
              {% endfor %}
            {% endif %}

            <!-- 2. Document Link (List of Files/URLs or Single File/URL) -->
            {% assign docs_value = blank %}
            {% assign docs_type = blank %}
            {% if product.metafields.custom.document_link.value != blank %}
              {% assign docs_value = product.metafields.custom.document_link.value %}
              {% assign docs_type = product.metafields.custom.document_link.type %}
            {% elsif product.metafields.custom.document_links.value != blank %}
              {% assign docs_value = product.metafields.custom.document_links.value %}
              {% assign docs_type = product.metafields.custom.document_links.type %}
            {% endif %}

            {% if docs_value != blank %}
              <g:document_link>
                {% if docs_type contains 'list' %}
                  {% assign doc_urls = "" %}
                  {% for doc in docs_value %}
                    {% assign doc_url = doc.url | default: doc %}
                    {% if doc_url != blank %}
                      {% assign first_two = doc_url | slice: 0, 2 %}
                      {% assign first_one = doc_url | slice: 0, 1 %}
                      {% if first_two == '//' %}
                        {% assign doc_url = doc_url | prepend: 'https:' %}
                      {% elsif first_one == '/' %}
                        {% assign doc_url = doc_url | prepend: shop.url %}
                      {% endif %}
                      {% assign doc_urls = doc_urls | append: doc_url | append: "," %}
                    {% endif %}
                  {% endfor %}
                  {{ doc_urls | split: "," | compact | join: "," }}
                {% else %}
                  {% assign doc_url = docs_value.url | default: docs_value %}
                  {% assign first_two = doc_url | slice: 0, 2 %}
                  {% assign first_one = doc_url | slice: 0, 1 %}
                  {% if first_two == '//' %}
                    {% assign doc_url = doc_url | prepend: 'https:' %}
                  {% elsif first_one == '/' %}
                    {% assign doc_url = doc_url | prepend: shop.url %}
                  {% endif %}
                  {{ doc_url }}
                {% endif %}
              </g:document_link>
            {% endif %}

            <!-- 3. Related / Complementary Products (Handles lists or single product references) -->
            {% assign metafield_sources = "shopify--discovery--product_recommendation.complementary_products,custom.related_accessories,custom.related_products,custom.complimentary_products,custom.complementary_products" | split: "," %}
            {% for source in metafield_sources %}
              {% assign parts = source | split: "." %}
              {% assign ns = parts[0] %}
              {% assign key = parts[1] %}
              {% assign value = product.metafields[ns][key].value %}
              
              {% if value != blank %}
                {% if product.metafields[ns][key].type contains 'list' %}
                  {% for p in value %}
                    {% assign rel_variant = p.first_available_variant | default: p.variants.first %}
                    {% assign rel_id = rel_variant.sku | default: rel_variant.id %}
                    {% if rel_id != blank %}
                      <g:related_product>
                        <g:relationship_type>accessory</g:relationship_type>
                        <g:identifier_type>id</g:identifier_type>
                        <g:identifier>{{ rel_id | xml_escape }}</g:identifier>
                      </g:related_product>
                    {% endif %}
                  {% endfor %}
                {% else %}
                  {% assign rel_variant = value.first_available_variant | default: value.variants.first %}
                  {% assign rel_id = rel_variant.sku | default: rel_variant.id %}
                  {% if rel_id != blank %}
                    <g:related_product>
                      <g:relationship_type>accessory</g:relationship_type>
                      <g:identifier_type>id</g:identifier_type>
                      <g:identifier>{{ rel_id | xml_escape }}</g:identifier>
                    </g:related_product>
                  {% endif %}
                {% endif %}
              {% endif %}
            {% endfor %}

            <!-- 4. Item Group Title -->
            {% if product.metafields.custom.item_group_title.value != blank %}
              <g:item_group_title>{{ product.metafields.custom.item_group_title.value | xml_escape }}</g:item_group_title>
            {% endif %}

            <!-- 5. Variant Option (Automated from native options) -->
            {% for option in product.options %}
              {% assign option_index = forloop.index %}
              {% case option_index %}
                {% when 1 %}
                  {% assign option_value = variant.option1 %}
                {% when 2 %}
                  {% assign option_value = variant.option2 %}
                {% when 3 %}
                  {% assign option_value = variant.option3 %}
              {% endcase %}
              {% if option_value != blank %}
                <g:variant_option>
                  <g:name>{{ option | xml_escape }}</g:name>
                  <g:value>{{ option_value | xml_escape }}</g:value>
                </g:variant_option>
              {% endif %}
            {% endfor %}

            <!-- 6. Popularity Rank -->
            {% if product.metafields.custom.popularity_rank.value != blank %}
              <g:popularity_rank>{{ product.metafields.custom.popularity_rank.value }}</g:popularity_rank>
            {% endif %}
          </item>
        {% endfor %}
      {% endfor %}
    {% endpaginate %}
  </channel>
</rss>
