{% layout none %}<?xml version="1.0"?>
<rss xmlns:g="http://base.google.com/ns/1.0" version="2.0">
  <channel>
    <title>{{ shop.name }} Conversational Feed</title>
    <link>{{ shop.url }}</link>
    <description>Supplemental feed for Google Merchant Center AI Shopping</description>
    {% paginate collections.all.products by 1000 %}
      {% for product in collections.all.products %}
        
        {% comment %} Cache product-level metafield values and types once {% endcomment %}
        {% assign faq_q_val = product.metafields.custom.faq_questions.value %}
        {% assign faq_q_type = product.metafields.custom.faq_questions.type %}
        {% assign faq_a_val = product.metafields.custom.faq_answers.value %}
        
        {% assign doc_val = product.metafields.custom.document_link.value %}
        {% assign doc_type = product.metafields.custom.document_link.type %}
        {% if doc_val == blank %}
          {% assign doc_val = product.metafields.custom.document_links.value %}
          {% assign doc_type = product.metafields.custom.document_links.type %}
        {% endif %}

        {% assign item_grp_title = product.metafields.custom.item_group_title.value %}
        {% assign pop_rank = product.metafields.custom.popularity_rank.value %}

        {% comment %} Pre-render related products XML for this product {% endcomment %}
        {% capture related_xml %}
          {% assign metafield_sources = "shopify--discovery--product_recommendation.complementary_products,custom.related_accessories,custom.related_products,custom.complimentary_products,custom.complementary_products" | split: "," %}
          {% for source in metafield_sources %}
            {% assign parts = source | split: "." %}
            {% assign ns = parts[0] %}
            {% assign key = parts[1] %}
            {% assign rel_meta = product.metafields[ns][key] %}
            {% assign rel_val = rel_meta.value %}
            
            {% if rel_val != blank %}
              {% if rel_meta.type contains 'list' %}
                {% for p in rel_val %}
                  {% assign rel_variant = p.first_available_variant | default: p.variants.first %}
                  {% assign rel_id = rel_variant.sku | default: rel_variant.id %}
                  {% if rel_id != blank %}
                    <g:related_product>
                      <g:relationship_type>accessory</g:relationship_type>
                      <g:identifier_type>id</g:identifier_type>
                      <g:identifier>{{ rel_id | xml_escape }}</g:identifier>
                    </g:related_product>
                  {% endif %}
                {% endfor %}
              {% else %}
                {% assign rel_variant = rel_val.first_available_variant | default: rel_val.variants.first %}
                {% assign rel_id = rel_variant.sku | default: rel_variant.id %}
                {% if rel_id != blank %}
                  <g:related_product>
                    <g:relationship_type>accessory</g:relationship_type>
                    <g:identifier_type>id</g:identifier_type>
                    <g:identifier>{{ rel_id | xml_escape }}</g:identifier>
                  </g:related_product>
                {% endif %}
              {% endif %}
            {% endif %}
          {% endfor %}
        {% endcapture %}

        {% comment %} Pre-render Q&A XML {% endcomment %}
        {% capture qa_xml %}
          {% if faq_q_val != blank %}
            {% if faq_q_type contains 'list' %}
              {% assign questions = faq_q_val %}
              {% assign answers = faq_a_val %}
            {% else %}
              {% capture newline %}
{% endcapture %}
              {% assign questions = faq_q_val | split: newline %}
              {% assign answers = faq_a_val | split: newline %}
            {% endif %}

            {% for question in questions %}
              {% assign clean_question = question | strip %}
              {% assign answer = answers[forloop.index0] | strip %}
              {% if clean_question != blank and answer != blank %}
                <g:question_and_answer>
                  <g:question>{{ clean_question | xml_escape }}</g:question>
                  <g:answer>{{ answer | xml_escape }}</g:answer>
                </g:question_and_answer>
              {% endif %}
            {% endfor %}
          {% endif %}
        {% endcapture %}

        {% comment %} Pre-render document link XML {% endcomment %}
        {% capture doc_xml %}
          {% if doc_val != blank %}
            <g:document_link>
              {% if doc_type contains 'list' %}
                {% assign doc_urls = "" %}
                {% for doc in doc_val %}
                  {% assign doc_url = doc.url | default: doc %}
                  {% if doc_url != blank %}
                    {% assign first_two = doc_url | slice: 0, 2 %}
                    {% assign first_one = doc_url | slice: 0, 1 %}
                    {% if first_two == '//' %}
                      {% assign doc_url = doc_url | prepend: 'https:' %}
                    {% elsif first_one == '/' %}
                      {% assign doc_url = doc_url | prepend: shop.url %}
                    {% endif %}
                    {% assign doc_urls = doc_urls | append: doc_url | append: "," %}
                  {% endif %}
                {% endfor %}
                {{ doc_urls | split: "," | compact | join: "," }}
              {% else %}
                {% assign doc_url = doc_val.url | default: doc_val %}
                {% assign first_two = doc_url | slice: 0, 2 %}
                {% assign first_one = doc_url | slice: 0, 1 %}
                {% if first_two == '//' %}
                  {% assign doc_url = doc_url | prepend: 'https:' %}
                {% elsif first_one == '/' %}
                  {% assign doc_url = doc_url | prepend: shop.url %}
                {% endif %}
                {{ doc_url }}
              {% endif %}
            </g:document_link>
          {% endif %}
        {% endcapture %}

        {% for variant in product.variants %}
          <item>
            <g:id>{{ variant.sku | xml_escape | default: variant.id }}</g:id>
            
            {{ qa_xml }}
            {{ doc_xml }}
            {{ related_xml }}

            {% if item_grp_title != blank %}
              <g:item_group_title>{{ item_grp_title | xml_escape }}</g:item_group_title>
            {% endif %}

            {% for option in product.options %}
              {% assign option_index = forloop.index %}
              {% case option_index %}
                {% when 1 %}
                  {% assign option_value = variant.option1 %}
                {% when 2 %}
                  {% assign option_value = variant.option2 %}
                {% when 3 %}
                  {% assign option_value = variant.option3 %}
              {% endcase %}
              {% if option_value != blank %}
                <g:variant_option>
                  <g:name>{{ option | xml_escape }}</g:name>
                  <g:value>{{ option_value | xml_escape }}</g:value>
                </g:variant_option>
              {% endif %}
            {% endfor %}

            {% if pop_rank != blank %}
              <g:popularity_rank>{{ pop_rank }}</g:popularity_rank>
            {% endif %}
          </item>
        {% endfor %}
      {% endfor %}
    {% endpaginate %}
  </channel>
</rss>
