    "rich_text_KKKqfT": {
      "type": "rich-text",
      "blocks": {
        "heading_fxQ9Kd": {
          "type": "heading",
          "settings": {
            "heading": "Why Choose Lily Blanche Jewellery?",
            "heading_size": "h1"
          }
        },
        "text_knUPjy": {
          "type": "text",
          "settings": {
            "text": "<p>✔<strong>100% Precious Metals</strong>– No base metals, only high-quality gold and silver.<br/>✔<strong>Ethically Sourced Gemstones</strong>– Natural stones selected for brilliance and beauty.<br/>✔<strong>Handcrafted by Experts</strong>– Created by master goldsmiths and silversmiths.<br/>✔<strong>Hallmarked & Certified</strong>– Guaranteed authenticity and premium quality.<br/>✔<strong>Designed to Last</strong>– Timeless, heirloom-worthy jewellery for every occasion.<br/><br/></p>"
          }
        }
      },
