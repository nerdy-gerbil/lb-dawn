    "custom_liquid_FLqcQn": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<!-- =====================================================\n     LILY BLANCHE — Micron Thickness Visualiser\n     Paste this into a Custom HTML section in Shopify\n     Theme Editor → Our Materials page → Add Section\n     → Custom HTML (or Custom Liquid)\n     ===================================================== -->\n\n<style>\n  .lb-micron-wrap {\n    max-width: 860px;\n    margin: 48px auto;\n    padding: 0 16px;\n    font-family: inherit;\n  }\n\n  .lb-micron-eyebrow {\n    font-size: 11px;\n    letter-spacing: 0.2em;\n    text-transform: uppercase;\n    color: #B8966A;\n    text-align: center;\n    margin-bottom: 10px;\n  }\n\n  .lb-micron-title {\n    font-size: 28px;\n    font-weight: 400;\n    text-align: center;\n    margin: 0 0 8px;\n    color: #000000;\n  }\n\n  .lb-micron-subtitle {\n    font-size: 13px;\n    color: #555555;\n    text-align: center;\n    margin: 0 0 40px;\n  }\n\n  .lb-micron-table {\n    border: 1px solid #E0D8CE;\n    background: #ffffff;\n    width: 100%;\n  }\n\n  .lb-micron-row {\n    display: grid !important;\n    grid-template-columns: 180px 1fr 80px;\n    align-items: center;\n    border-bottom: 1px solid #E0D8CE;\n  }\n\n  .lb-micron-row:last-child {\n    border-bottom: none;\n  }\n\n  .lb-micron-row--highlight {\n    background: #FAF7F2;\n  }\n\n  .lb-micron-label {\n    padding: 18px 20px;\n    font-size: 13px;\n    font-weight: 600;\n    color: #000000;\n    border-right: 1px solid #E0D8CE;\n    line-height: 1.3;\n  }\n\n  .lb-micron-label small {\n    display: block !important;\n    font-size: 11px;\n    font-weight: 400;\n    color: #555555;\n    margin-top: 3px;\n  }\n\n  .lb-micron-tag {\n    display: inline-block !important;\n    background: #B8966A;\n    color: #ffffff;\n    font-size: 9px;\n    font-weight: 600;\n    letter-spacing: 0.1em;\n    text-transform: uppercase;\n    padding: 2px 7px;\n    margin-top: 5px;\n  }\n\n  .lb-micron-track {\n    padding: 14px 20px;\n    overflow: hidden;\n  }\n\n  .lb-micron-bar {\n    display: block !important;\n    height: 14px !important;\n    min-height: 14px !important;\n    border-radius: 1px;\n    width: 0;\n    transition: width 1.4s cubic-bezier(0.16, 1, 0.3, 1);\n    visibility: visible !important;\n    opacity: 1 !important;\n  }\n\n  .lb-micron-bar[data-w=\"flash\"]  { background: #C8C0B8 !important; }\n  .lb-micron-bar[data-w=\"plated\"] { background: #D4B896 !important; }\n  .lb-micron-bar[data-w=\"legal\"]  { background: #C4A07A !important; }\n  .lb-micron-bar[data-w=\"lb\"]     { background: #B8966A !important; }\n  .lb-micron-bar[data-w=\"solid\"]  {\n    background: repeating-linear-gradient(\n      45deg,\n      #B8966A 0px, #B8966A 4px,\n      #8C6E4A 4px, #8C6E4A 8px\n    ) !important;\n  }\n\n  .lb-micron-value {\n    padding: 18px 14px 18px 10px;\n    font-size: 17px;\n    font-weight: 400;\n    color: #000000;\n    text-align: right;\n    border-left: 1px solid #E0D8CE;\n    white-space: nowrap;\n  }\n\n  .lb-micron-row--highlight .lb-micron-value {\n    color: #B8966A;\n    font-weight: 700;\n  }\n\n  .lb-micron-caption {\n    font-size: 12px;\n    color: #555555;\n    text-align: center;\n    margin-top: 14px;\n  }\n\n  /* Mobile */\n  @media (max-width: 600px) {\n    .lb-micron-row {\n      grid-template-columns: 130px 1fr 56px !important;\n    }\n    .lb-micron-label {\n      padding: 14px 12px;\n      font-size: 11px;\n    }\n    .lb-micron-value {\n      font-size: 12px;\n      padding: 14px 8px;\n    }\n    .lb-micron-track {\n      padding: 14px 12px;\n    }\n    .lb-micron-title {\n      font-size: 22px;\n    }\n  }\n\n  @media (prefers-reduced-motion: reduce) {\n    .lb-micron-bar { transition: none !important; }\n  }\n</style>\n\n<div class=\"lb-micron-wrap\" id=\"lb-micron-wrap\">\n\n \n  <h1 class=\"lb-micron-title\">Why microns matter</h1>\n  <p class=\"lb-micron-subtitle\">The thickness of gold determines how long your jewellery lasts. Here's how Lily Blanche compares — shown to scale.</p>\n\n  <div class=\"lb-micron-table\">\n\n    <div class=\"lb-micron-row\">\n      <div class=\"lb-micron-label\">Flash Plated<small>Budget jewellery</small></div>\n      <div class=\"lb-micron-track\">\n        <div class=\"lb-micron-bar\" data-w=\"flash\" data-target=\"2.5\"></div>\n      </div>\n      <div class=\"lb-micron-value\">0.125µm</div>\n    </div>\n\n    <div class=\"lb-micron-row\">\n      <div class=\"lb-micron-label\">Gold Plated<small>Industry standard</small></div>\n      <div class=\"lb-micron-track\">\n        <div class=\"lb-micron-bar\" data-w=\"plated\" data-target=\"21\"></div>\n      </div>\n      <div class=\"lb-micron-value\">0.5µm</div>\n    </div>\n\n    <div class=\"lb-micron-row\">\n      <div class=\"lb-micron-label\">Vermeil (Legal)<small>US minimum standard</small></div>\n      <div class=\"lb-micron-track\">\n        <div class=\"lb-micron-bar\" data-w=\"legal\" data-target=\"42\"></div>\n      </div>\n      <div class=\"lb-micron-value\">2.5µm</div>\n    </div>\n\n    <div class=\"lb-micron-row lb-micron-row--highlight\">\n      <div class=\"lb-micron-label\">Lily Blanche Vermeil<small>Our standard</small><span class=\"lb-micron-tag\">Our pieces</span></div>\n      <div class=\"lb-micron-track\">\n        <div class=\"lb-micron-bar\" data-w=\"lb\" data-target=\"100\"></div>\n      </div>\n      <div class=\"lb-micron-value\">3µm+</div>\n    </div>\n\n    <div class=\"lb-micron-row\">\n      <div class=\"lb-micron-label\">Solid Gold<small>No plating required</small></div>\n      <div class=\"lb-micron-track\">\n        <div class=\"lb-micron-bar\" data-w=\"solid\" data-target=\"100\"></div>\n      </div>\n      <div class=\"lb-micron-value\">Solid</div>\n    </div>\n\n  </div>\n\n  <p class=\"lb-micron-caption\">Bars shown proportionally. Lily Blanche vermeil is 24&times; thicker than flash-plated gold.</p>\n\n</div>\n\n<script>\n(function() {\n  // Run immediately AND on DOMContentLoaded to handle both\n  // inline execution and deferred script scenarios in Shopify\n  function init() {\n    var wrap = document.getElementById('lb-micron-wrap');\n    if (!wrap) return;\n    var bars = wrap.querySelectorAll('.lb-micron-bar');\n    var animated = false;\n\n    function animateBars() {\n      if (animated) return;\n      animated = true;\n      bars.forEach(function(bar, i) {\n        var target = bar.getAttribute('data-target') + '%';\n        setTimeout(function() {\n          bar.style.width = target;\n        }, i * 180);\n      });\n    }\n\n    if ('IntersectionObserver' in window) {\n      var observer = new IntersectionObserver(function(entries) {\n        entries.forEach(function(entry) {\n          if (entry.isIntersecting) {\n            animateBars();\n            observer.disconnect();\n          }\n        });\n      }, { threshold: 0.2 });\n      observer.observe(wrap);\n    } else {\n      // Fallback: just animate after a short delay\n      setTimeout(animateBars, 400);\n    }\n  }\n\n  if (document.readyState === 'loading') {\n    document.addEventListener('DOMContentLoaded', init);\n  } else {\n    init();\n  }\n})();\n</script>",
        "color_scheme": "",
        "padding_top": 40,
        "padding_bottom": 52
      }
    },
