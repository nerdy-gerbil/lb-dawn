    "multicolumn_wE8dne": {
      "type": "multicolumn",
      "blocks": {
        "column_Vm6UUw": {
          "type": "column",
          "settings": {
            "title": "<strong>Timing Matters</strong>",
            "text": "<p>Your finger size constantly changes throughout the day due to temperature, activity and fluid retention. To get the most accurate measurement, size your finger at the end of the day when your fingers are at their largest. </p>",
            "link_label": "",
            "link": ""
          }
        },
        "column_QFRX8r": {
          "type": "column",
          "settings": {
            "title": "<strong>Measure Multiple Times</strong>",
            "text": "<p>For accuracy, measure your finger size at least three times on different days. If you get varied results, choose the measurement that is in the middle. If your results are consistant this indicates a reliable size. </p>",
            "link_label": "",
            "link": ""
          }
        },
        "column_fWgK9c": {
          "type": "column",
          "settings": {
            "title": "<strong>Knuckle Considerations</strong>",
            "text": "<p>If you have a knuckle that is much bigger than the base of your finger, measure both areas and choose the size between the two of these measurements. The ring needs to be able to slide over your knuckle but not be so loose that it can easily spin on your finger.</p>",
            "link_label": "",
            "link": ""
          }
        }
      },
      "block_order": [
        "column_Vm6UUw",
        "column_QFRX8r",
        "column_fWgK9c"
      ],
