    "rich_text_rgeJxa": {
      "type": "rich-text",
      "blocks": {
        "heading_nEtPgR": {
          "type": "heading",
          "settings": {
            "heading": "Quick Size Reference",
            "heading_size": "h1"
          }
        },
        "text_NyJnbh": {
          "type": "text",
          "settings": {
            "text": "<p><strong>Most Popular Women's Sizes: </strong>L (UK) / 6 (US) to P (UK) / 8 (US)</p><p><strong>Most Popular Men's Sizes: </strong>R (UK) / 9 (US) to V (UK) / 11 (US)</p><p><strong>Average Sizes: Women:</strong> N (UK) / 7 (US) | Men: T (UK) / 10 (US)</p>"
          }
        }
      },
      "block_order": [
