{% for group in robots.default_groups %}
  {{- group.user_agent -}}

  {% for rule in group.rules %}
    {%- unless rule.value contains '/*' -%}
      {{- rule -}}
    {%- else -%}
      {%- comment -%} Lighthouse parser workaround for Shopify wildcards {%- endcomment -%}
      {{- rule.directive -}}: {{ rule.value | remove: '/*' | prepend: '/' | replace: '//', '/' }}
    {%- endunless -%}
  {% endfor %}

  {%- if group.sitemap != blank -%}
    {{ group.sitemap }}
  {%- endif -%}
{% endfor %}
